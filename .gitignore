# Track ONLY these two folders
/*
!forex-command-centre/
!forex-alert-server/
!.gitignore

# Credentials - NEVER commit
forex-command-centre/config/broker-config.json
forex-command-centre/data/broker-config.json
forex-command-centre/backend/scripts/myfxbook-config.json

# Runtime data files
forex-command-centre/data/trades.json
forex-command-centre/data/session-board.json
forex-command-centre/data/regime.json
forex-command-centre/data/playbook.json
forex-command-centre/data/circuit-breaker.json
forex-command-centre/data/settings.json
forex-command-centre/data/armed-dismissed.json
forex-command-centre/data/armed-exclude.json
forex-command-centre/data/armed-validation.json
forex-command-centre/data/armed-watchlist.json
forex-command-centre/data/bias-history.json
forex-command-centre/data/bias-history.json.lock
forex-command-centre/data/dashboard-theme.json
forex-command-centre/src/scraper_health.json
forex-command-centre/backups/

# Scratch / probe files (not source-of-truth)
forex-command-centre/backend/scripts/ig-sentiment-config.json
forex-command-centre/backend/scripts/myfxbook_probe_*.py

# Alert server runtime
forex-alert-server/data/armed.json
forex-alert-server/data/utcc-alerts.json
forex-alert-server/data/candidates.json

# Node & OS
node_modules/
.DS_Store
*.swp
*.bak
*.backup
!utcc-indicators/

# Python
**/__pycache__/
*.pyc
