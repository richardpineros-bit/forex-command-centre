//@version=6
// ══════════════════════════════════════════════════════════════════════════════
// FCC S/R Location Zones — v1.0.0
// Forex Command Centre — combined S/R visual + location grading + FCC webhook
//
// Replaces:
//   sr-location-zones.pine  (visual zones only)
//   location-engine.pine    (webhook only)
//
// Auto-detects asset class: FX | METALS | ENERGY | INDICES | CRYPTO | BONDS
// Applies calibrated profile per class. All values manually overrideable.
//
// What it does:
//   1. Draws S/R zones: Weekly/Daily swings, PDH/PDL, PWH/PWL,
//      round numbers, Daily 200 EMA — ATR-scaled boxes, colour-coded
//   2. Touch counting: WEAK / MODERATE / STRONG / EXHAUSTED
//   3. Confluence detection: flags when 2+ sources overlap
//   4. Grades entry location: PRIME / AT_ZONE / AT_CLOUD / IN_CLOUD /
//      WAIT / OPPOSED / BREAKOUT_RETEST / BREAKOUT_EXT / FALSE_BREAK
//   5. Fires webhook to FCC alert server on every bar close
//
// Webhook payload (JSON):
//   {"pair":"EURUSD","asset_class":"FX","direction":"LONG","grade":"PRIME",
//    "zone":"D.SwingL","zone_dist_atr":"0.12","cloud_pos":"AT_LOWER_EDGE",
//    "cloud_dist_atr":"0.08","breakout":"NONE","supp_name":"D.SwingL",
//    "supp_dist_atr":"0.12","res_name":"PDH","res_dist_atr":"1.4"}
//
// Setup:
//   1. Add to each pair on 4H chart (works on 1H and Daily too)
//   2. One TradingView alert per pair — Any Alert() — Webhook:
//      https://api.pineros.club/webhook/location
//   3. Leave alert message blank — indicator sets it dynamically
// ══════════════════════════════════════════════════════════════════════════════

indicator("FCC S/R Location Zones", shorttitle="FCC-SRL", overlay=true,
     max_boxes_count=200, max_labels_count=200, max_lines_count=10)

// ══════════════════════════════════════════════════════════════════════════════
// ASSET CLASS DETECTION — mirrors UTCC Universal logic exactly
// Priority: CRYPTO > METALS > ENERGY > BONDS > INDICES > FX
// ══════════════════════════════════════════════════════════════════════════════

_t = str.upper(syminfo.ticker)

bool _isCrypto = syminfo.type == "crypto"
_isCrypto := _isCrypto or str.contains(_t, "BITCOIN") or str.contains(_t, "BTCUSD") or str.contains(_t, "BTC_")
_isCrypto := _isCrypto or str.contains(_t, "ETHEREUM") or str.contains(_t, "ETHUSD") or str.contains(_t, "ETH_")
_isCrypto := _isCrypto or str.contains(_t, "LTCUSD") or str.contains(_t, "XRPUSD") or str.contains(_t, "BCHUSD")
_isCrypto := _isCrypto or str.contains(_t, "SOLUSD") or str.contains(_t, "ADAUSD") or str.contains(_t, "DOTUSD")
_isCrypto := _isCrypto or str.contains(_t, "LINKUSD") or str.contains(_t, "AVAXUSD") or str.contains(_t, "MATICUSD")

bool _isMetals = str.contains(_t, "XAUUSD") or str.contains(_t, "XAGUSD")
_isMetals := _isMetals or str.contains(_t, "XAUEUR") or str.contains(_t, "XAGEUR")
_isMetals := _isMetals or str.contains(_t, "COPPER") or str.contains(_t, "XPTUSD") or str.contains(_t, "XPDUSD")
_isMetals := _isMetals or str.contains(_t, "XAU") or str.contains(_t, "XAG") or str.contains(_t, "XPT") or str.contains(_t, "XPD")
_isMetals := _isMetals or (syminfo.type == "futures" and (str.startswith(_t, "GC") or str.startswith(_t, "SI") or str.startswith(_t, "HG")))

bool _isEnergy = str.contains(_t, "WTICOUSD") or str.contains(_t, "BCOUSD") or str.contains(_t, "NATGASUSD")
_isEnergy := _isEnergy or str.contains(_t, "USOIL") or str.contains(_t, "UKOIL") or str.contains(_t, "NGAS")
_isEnergy := _isEnergy or str.contains(_t, "WTI") or str.contains(_t, "BRENT") or str.contains(_t, "CRUDE")
_isEnergy := _isEnergy or (syminfo.type == "futures" and (str.startswith(_t, "CL") or str.startswith(_t, "LCO")))

bool _isBonds = syminfo.type == "bond"
_isBonds := _isBonds or str.contains(_t, "US02Y") or str.contains(_t, "US10Y") or str.contains(_t, "US30Y")
_isBonds := _isBonds or str.contains(_t, "BUND") or str.contains(_t, "GILT") or str.contains(_t, "JGB")
_isBonds := _isBonds or (syminfo.type == "futures" and (str.startswith(_t, "ZB") or str.startswith(_t, "ZN") or str.startswith(_t, "ZF")))

bool _isIndices = syminfo.type == "index"
_isIndices := _isIndices or str.contains(_t, "SPX") or str.contains(_t, "NAS") or str.contains(_t, "DAX")
_isIndices := _isIndices or str.contains(_t, "FTSE") or str.contains(_t, "NIKKEI") or str.contains(_t, "ASX")
_isIndices := _isIndices or str.contains(_t, "JP225") or str.contains(_t, "AU200") or str.contains(_t, "US500")
_isIndices := _isIndices or str.contains(_t, "WALL") or str.contains(_t, "USTECH") or str.contains(_t, "FT100")
_isIndices := _isIndices or (syminfo.type == "futures" and (str.startswith(_t, "ES") or str.startswith(_t, "NQ") or str.startswith(_t, "YM")))

string detectedClass = "FX"
if _isCrypto and not _isMetals
    detectedClass := "CRYPTO"
else if _isMetals
    detectedClass := "METALS"
else if _isEnergy
    detectedClass := "ENERGY"
else if _isBonds
    detectedClass := "BONDS"
else if _isIndices
    detectedClass := "INDICES"

// ══════════════════════════════════════════════════════════════════════════════
// INPUTS — GENERAL
// ══════════════════════════════════════════════════════════════════════════════

grpGen = "General"
manualClass  = input.string("AUTO", "Asset Class Override", group=grpGen,
                options=["AUTO","FX","METALS","ENERGY","INDICES","CRYPTO","BONDS"],
                tooltip="AUTO = auto-detected. Override if detection is wrong for an unusual instrument.")
showDetected = input.bool(true, "Show Detected Class on Chart", group=grpGen,
                tooltip="Shows [FX], [METALS] etc in the grade label to confirm detection is correct.")
showLbls     = input.bool(true,  "Show Zone Labels",            group=grpGen)
lblSize      = input.string("small", "Label Size",              group=grpGen, options=["tiny","small","normal","large"])
extRight     = input.int(20,  "Extend Boxes Right (bars)",      group=grpGen, minval=0, maxval=200)
showCloud    = input.bool(true, "Show EMA Cloud",               group=grpGen)
alertEveryBar = input.bool(true, "Webhook Every Bar Close",     group=grpGen,
                tooltip="ON = fires every bar close. OFF = only on grade change.")
showGradeLbl  = input.bool(true, "Show Grade Label on Chart",   group=grpGen)

assetClass = manualClass == "AUTO" ? detectedClass : manualClass

// ══════════════════════════════════════════════════════════════════════════════
// INPUTS — ZONE SOURCES
// ══════════════════════════════════════════════════════════════════════════════

grpSrc      = "Zone Sources"
showDSwings = input.bool(true, "Daily Swings",         group=grpSrc)
showWSwings = input.bool(true, "Weekly Swings",        group=grpSrc)
showPDH     = input.bool(true, "Prev Day High (PDH)",  group=grpSrc)
showPDL     = input.bool(true, "Prev Day Low (PDL)",   group=grpSrc)
showPWH     = input.bool(true, "Prev Week High (PWH)", group=grpSrc)
showPWL     = input.bool(true, "Prev Week Low (PWL)",  group=grpSrc)
showRound   = input.bool(true, "Round Numbers",        group=grpSrc)
showEMA200  = input.bool(true, "Daily 200 EMA Zone",   group=grpSrc)
dLookback   = input.int(500, "Daily Search Depth (bars)",  group=grpSrc, minval=50, maxval=1500)
wLookback   = input.int(500, "Weekly Search Depth (bars)", group=grpSrc, minval=50, maxval=1500)
maxRounds   = input.int(4,   "Round Number Levels Above & Below", group=grpSrc, minval=1, maxval=10)
tchLookback = input.int(300, "Touch Count Lookback (bars)", group=grpSrc, minval=50, maxval=1000)

// ══════════════════════════════════════════════════════════════════════════════
// INPUTS — COLOURS
// ══════════════════════════════════════════════════════════════════════════════

grpC        = "Colours"
cWeekly     = input.color(color.new(#FF3366, 20), "Weekly Swing",            group=grpC)
cDaily      = input.color(color.new(#FF8C00, 25), "Daily Swing",             group=grpC)
cPrevDay    = input.color(color.new(#00BFFF, 25), "Prev Day H/L",            group=grpC)
cPrevWeek   = input.color(color.new(#9370DB, 25), "Prev Week H/L",           group=grpC)
cRound      = input.color(color.new(#20C997, 35), "Round Numbers",           group=grpC)
cEMA        = input.color(color.new(#FFD700, 35), "Daily 200 EMA",           group=grpC)
cConfluence = input.color(color.new(#FF4444, 10), "Confluence (2+ sources)", group=grpC)
cExhausted  = input.color(color.new(#888888, 45), "Exhausted Zone",          group=grpC)
cCloudBull  = input.color(color.new(#00C853, 82), "Cloud Bull",              group=grpC)
cCloudBear  = input.color(color.new(#FF1744, 82), "Cloud Bear",              group=grpC)
cCloudNeut  = input.color(color.new(#888888, 88), "Cloud Neutral",           group=grpC)

// ══════════════════════════════════════════════════════════════════════════════
// INPUTS — DIRECTION EMAs
// ══════════════════════════════════════════════════════════════════════════════

grpDir   = "Direction EMAs"
dirMode  = input.string("AUTO", "Direction Mode", group=grpDir,
            options=["AUTO","LONG","SHORT"],
            tooltip="AUTO uses 9/21/50 EMA stack direction. Override if needed.")
ema9Len  = input.int(9,  "Direction Fast EMA",  group=grpDir, minval=1, maxval=50)
ema21Len = input.int(21, "Direction Mid EMA",   group=grpDir, minval=1, maxval=100)
ema50Len = input.int(50, "Direction Slow EMA",  group=grpDir, minval=1, maxval=200)

// ══════════════════════════════════════════════════════════════════════════════
// INPUTS — BREAKOUT DETECTION
// ══════════════════════════════════════════════════════════════════════════════

grpBrk        = "Breakout Detection"
useBreakout   = input.bool(true,  "Enable Breakout Detection", group=grpBrk)
retestProxMul = input.float(0.3,  "Retest Tolerance ATR x",    group=grpBrk, minval=0.1, maxval=1.0, step=0.1)
falseBreakMul = input.float(0.2,  "False Break Threshold ATR x",group=grpBrk, minval=0.05, maxval=0.5, step=0.05)

// ══════════════════════════════════════════════════════════════════════════════
// PROFILE — FX
// ══════════════════════════════════════════════════════════════════════════════

grpFX           = "Profile: FX"
fx_zoneHW       = input.float(0.15, "Zone Half-Width ATR x",           group=grpFX, minval=0.05, maxval=2.0, step=0.05)
fx_zoneProx     = input.float(0.4,  "Zone Proximity ATR x",            group=grpFX, minval=0.1,  maxval=3.0, step=0.05)
fx_dPivLen      = input.int(7,      "Daily Pivot Strength",             group=grpFX, minval=2, maxval=15)
fx_wPivLen      = input.int(4,      "Weekly Pivot Strength",            group=grpFX, minval=1, maxval=10)
fx_dMaxZones    = input.int(3,      "Max Daily Zones (each direction)", group=grpFX, minval=1, maxval=15)
fx_wMaxZones    = input.int(2,      "Max Weekly Zones (each direction)",group=grpFX, minval=1, maxval=10)
fx_cloudFast    = input.int(9,      "Cloud Fast EMA",                   group=grpFX, minval=1, maxval=50)
fx_cloudSlow    = input.int(21,     "Cloud Slow EMA",                   group=grpFX, minval=1, maxval=200)
fx_cloudProx    = input.float(0.5,  "Cloud Proximity ATR x",            group=grpFX, minval=0.1, maxval=3.0, step=0.1)
fx_emaBuf       = input.float(0.5,  "200 EMA Zone Width ATR x",         group=grpFX, minval=0.1, maxval=3.0, step=0.1)
fx_tchCooldown  = input.int(3,      "Touch Cooldown (bars)",             group=grpFX, minval=1, maxval=30)
fx_exhausted    = input.int(4,      "Exhausted At (touches)",            group=grpFX, minval=2, maxval=10)
fx_minRoundTch  = input.int(2,      "Min Round Number Touches",          group=grpFX, minval=0, maxval=5)
fx_roundIncr    = input.float(0.0,  "Round Number Increment (0=auto)",   group=grpFX, minval=0, step=0.0001)
fx_retestWin    = input.int(2,      "Breakout Retest Window (bars)",     group=grpFX, minval=1, maxval=8)

// ══════════════════════════════════════════════════════════════════════════════
// PROFILE — METALS
// ══════════════════════════════════════════════════════════════════════════════

grpMET          = "Profile: Metals"
met_zoneHW      = input.float(0.4,  "Zone Half-Width ATR x",           group=grpMET, minval=0.05, maxval=2.0, step=0.05)
met_zoneProx    = input.float(0.6,  "Zone Proximity ATR x",            group=grpMET, minval=0.1,  maxval=3.0, step=0.05)
met_dPivLen     = input.int(7,      "Daily Pivot Strength",             group=grpMET, minval=2, maxval=15)
met_wPivLen     = input.int(4,      "Weekly Pivot Strength",            group=grpMET, minval=1, maxval=10)
met_dMaxZones   = input.int(3,      "Max Daily Zones (each direction)", group=grpMET, minval=1, maxval=15)
met_wMaxZones   = input.int(2,      "Max Weekly Zones (each direction)",group=grpMET, minval=1, maxval=10)
met_cloudFast   = input.int(9,      "Cloud Fast EMA",                   group=grpMET, minval=1, maxval=50)
met_cloudSlow   = input.int(34,     "Cloud Slow EMA",                   group=grpMET, minval=1, maxval=200)
met_cloudProx   = input.float(0.7,  "Cloud Proximity ATR x",            group=grpMET, minval=0.1, maxval=3.0, step=0.1)
met_emaBuf      = input.float(0.8,  "200 EMA Zone Width ATR x",         group=grpMET, minval=0.1, maxval=3.0, step=0.1)
met_tchCooldown = input.int(5,      "Touch Cooldown (bars)",             group=grpMET, minval=1, maxval=30)
met_exhausted   = input.int(5,      "Exhausted At (touches)",            group=grpMET, minval=2, maxval=10)
met_minRoundTch = input.int(2,      "Min Round Number Touches",          group=grpMET, minval=0, maxval=5)
met_roundIncr   = input.float(10.0, "Round Number Increment",            group=grpMET, minval=0, step=0.5,
                   tooltip="Gold=10, Silver=0.5")
met_retestWin   = input.int(3,      "Breakout Retest Window (bars)",     group=grpMET, minval=1, maxval=8)

// ══════════════════════════════════════════════════════════════════════════════
// PROFILE — ENERGY
// ══════════════════════════════════════════════════════════════════════════════

grpENE          = "Profile: Energy"
ene_zoneHW      = input.float(0.5,  "Zone Half-Width ATR x",           group=grpENE, minval=0.05, maxval=2.0, step=0.05)
ene_zoneProx    = input.float(0.7,  "Zone Proximity ATR x",            group=grpENE, minval=0.1,  maxval=3.0, step=0.05)
ene_dPivLen     = input.int(7,      "Daily Pivot Strength",             group=grpENE, minval=2, maxval=15)
ene_wPivLen     = input.int(4,      "Weekly Pivot Strength",            group=grpENE, minval=1, maxval=10)
ene_dMaxZones   = input.int(3,      "Max Daily Zones (each direction)", group=grpENE, minval=1, maxval=15)
ene_wMaxZones   = input.int(2,      "Max Weekly Zones (each direction)",group=grpENE, minval=1, maxval=10)
ene_cloudFast   = input.int(9,      "Cloud Fast EMA",                   group=grpENE, minval=1, maxval=50)
ene_cloudSlow   = input.int(34,     "Cloud Slow EMA",                   group=grpENE, minval=1, maxval=200)
ene_cloudProx   = input.float(0.8,  "Cloud Proximity ATR x",            group=grpENE, minval=0.1, maxval=3.0, step=0.1)
ene_emaBuf      = input.float(0.9,  "200 EMA Zone Width ATR x",         group=grpENE, minval=0.1, maxval=3.0, step=0.1)
ene_tchCooldown = input.int(6,      "Touch Cooldown (bars)",             group=grpENE, minval=1, maxval=30)
ene_exhausted   = input.int(5,      "Exhausted At (touches)",            group=grpENE, minval=2, maxval=10)
ene_minRoundTch = input.int(2,      "Min Round Number Touches",          group=grpENE, minval=0, maxval=5)
ene_roundIncr   = input.float(1.0,  "Round Number Increment",            group=grpENE, minval=0, step=0.5)
ene_retestWin   = input.int(3,      "Breakout Retest Window (bars)",     group=grpENE, minval=1, maxval=8)

// ══════════════════════════════════════════════════════════════════════════════
// PROFILE — INDICES
// ══════════════════════════════════════════════════════════════════════════════

grpIDX          = "Profile: Indices"
idx_zoneHW      = input.float(0.3,  "Zone Half-Width ATR x",           group=grpIDX, minval=0.05, maxval=2.0, step=0.05)
idx_zoneProx    = input.float(0.5,  "Zone Proximity ATR x",            group=grpIDX, minval=0.1,  maxval=3.0, step=0.05)
idx_dPivLen     = input.int(5,      "Daily Pivot Strength",             group=grpIDX, minval=2, maxval=15)
idx_wPivLen     = input.int(3,      "Weekly Pivot Strength",            group=grpIDX, minval=1, maxval=10)
idx_dMaxZones   = input.int(3,      "Max Daily Zones (each direction)", group=grpIDX, minval=1, maxval=15)
idx_wMaxZones   = input.int(2,      "Max Weekly Zones (each direction)",group=grpIDX, minval=1, maxval=10)
idx_cloudFast   = input.int(9,      "Cloud Fast EMA",                   group=grpIDX, minval=1, maxval=50)
idx_cloudSlow   = input.int(21,     "Cloud Slow EMA",                   group=grpIDX, minval=1, maxval=200)
idx_cloudProx   = input.float(0.6,  "Cloud Proximity ATR x",            group=grpIDX, minval=0.1, maxval=3.0, step=0.1)
idx_emaBuf      = input.float(0.6,  "200 EMA Zone Width ATR x",         group=grpIDX, minval=0.1, maxval=3.0, step=0.1)
idx_tchCooldown = input.int(4,      "Touch Cooldown (bars)",             group=grpIDX, minval=1, maxval=30)
idx_exhausted   = input.int(4,      "Exhausted At (touches)",            group=grpIDX, minval=2, maxval=10)
idx_minRoundTch = input.int(2,      "Min Round Number Touches",          group=grpIDX, minval=0, maxval=5)
idx_roundIncr   = input.float(50.0, "Round Number Increment",            group=grpIDX, minval=0, step=10.0,
                   tooltip="e.g. S&P500=50, Nasdaq=100, DAX=100, AU200=50")
idx_retestWin   = input.int(2,      "Breakout Retest Window (bars)",     group=grpIDX, minval=1, maxval=8)

// ══════════════════════════════════════════════════════════════════════════════
// PROFILE — CRYPTO
// ══════════════════════════════════════════════════════════════════════════════

grpCRY          = "Profile: Crypto"
cry_zoneHW      = input.float(0.6,   "Zone Half-Width ATR x",           group=grpCRY, minval=0.05, maxval=2.0, step=0.05)
cry_zoneProx    = input.float(0.8,   "Zone Proximity ATR x",            group=grpCRY, minval=0.1,  maxval=3.0, step=0.05)
cry_dPivLen     = input.int(8,       "Daily Pivot Strength",             group=grpCRY, minval=2, maxval=15)
cry_wPivLen     = input.int(5,       "Weekly Pivot Strength",            group=grpCRY, minval=1, maxval=10)
cry_dMaxZones   = input.int(3,       "Max Daily Zones (each direction)", group=grpCRY, minval=1, maxval=15)
cry_wMaxZones   = input.int(2,       "Max Weekly Zones (each direction)",group=grpCRY, minval=1, maxval=10)
cry_cloudFast   = input.int(9,       "Cloud Fast EMA",                   group=grpCRY, minval=1, maxval=50)
cry_cloudSlow   = input.int(21,      "Cloud Slow EMA",                   group=grpCRY, minval=1, maxval=200)
cry_cloudProx   = input.float(1.0,   "Cloud Proximity ATR x",            group=grpCRY, minval=0.1, maxval=3.0, step=0.1)
cry_emaBuf      = input.float(1.2,   "200 EMA Zone Width ATR x",         group=grpCRY, minval=0.1, maxval=3.0, step=0.1)
cry_tchCooldown = input.int(4,       "Touch Cooldown (bars)",             group=grpCRY, minval=1, maxval=30)
cry_exhausted   = input.int(3,       "Exhausted At (touches)",            group=grpCRY, minval=2, maxval=10)
cry_minRoundTch = input.int(1,       "Min Round Number Touches",          group=grpCRY, minval=0, maxval=5)
cry_roundIncr   = input.float(1000.0,"Round Number Increment",            group=grpCRY, minval=0, step=100.0,
                   tooltip="BTC=1000, ETH=100, smaller alts=10")
cry_retestWin   = input.int(3,       "Breakout Retest Window (bars)",     group=grpCRY, minval=1, maxval=8)

// ══════════════════════════════════════════════════════════════════════════════
// PROFILE — BONDS
// ══════════════════════════════════════════════════════════════════════════════

grpBND          = "Profile: Bonds"
bnd_zoneHW      = input.float(0.3,  "Zone Half-Width ATR x",           group=grpBND, minval=0.05, maxval=2.0, step=0.05)
bnd_zoneProx    = input.float(0.4,  "Zone Proximity ATR x",            group=grpBND, minval=0.1,  maxval=3.0, step=0.05)
bnd_dPivLen     = input.int(6,      "Daily Pivot Strength",             group=grpBND, minval=2, maxval=15)
bnd_wPivLen     = input.int(4,      "Weekly Pivot Strength",            group=grpBND, minval=1, maxval=10)
bnd_dMaxZones   = input.int(3,      "Max Daily Zones (each direction)", group=grpBND, minval=1, maxval=15)
bnd_wMaxZones   = input.int(2,      "Max Weekly Zones (each direction)",group=grpBND, minval=1, maxval=10)
bnd_cloudFast   = input.int(9,      "Cloud Fast EMA",                   group=grpBND, minval=1, maxval=50)
bnd_cloudSlow   = input.int(21,     "Cloud Slow EMA",                   group=grpBND, minval=1, maxval=200)
bnd_cloudProx   = input.float(0.5,  "Cloud Proximity ATR x",            group=grpBND, minval=0.1, maxval=3.0, step=0.1)
bnd_emaBuf      = input.float(0.5,  "200 EMA Zone Width ATR x",         group=grpBND, minval=0.1, maxval=3.0, step=0.1)
bnd_tchCooldown = input.int(3,      "Touch Cooldown (bars)",             group=grpBND, minval=1, maxval=30)
bnd_exhausted   = input.int(4,      "Exhausted At (touches)",            group=grpBND, minval=2, maxval=10)
bnd_minRoundTch = input.int(2,      "Min Round Number Touches",          group=grpBND, minval=0, maxval=5)
bnd_roundIncr   = input.float(0.5,  "Round Number Increment",            group=grpBND, minval=0, step=0.25)
bnd_retestWin   = input.int(2,      "Breakout Retest Window (bars)",     group=grpBND, minval=1, maxval=8)

// ══════════════════════════════════════════════════════════════════════════════
// RESOLVE ACTIVE PROFILE
// ══════════════════════════════════════════════════════════════════════════════

zoneHW      = fx_zoneHW
zoneProxMul = fx_zoneProx
dPiv        = fx_dPivLen
wPiv        = fx_wPivLen
dMaxZones   = fx_dMaxZones
wMaxZones   = fx_wMaxZones
cloudFastL  = fx_cloudFast
cloudSlowL  = fx_cloudSlow
cloudProx   = fx_cloudProx
emaBufMul   = fx_emaBuf
tchCooldown = fx_tchCooldown
exhaustedAt = fx_exhausted
minRoundTch = fx_minRoundTch
roundIncr   = fx_roundIncr
retestWin   = fx_retestWin

if assetClass == "METALS"
    zoneHW      := met_zoneHW
    zoneProxMul := met_zoneProx
    dPiv        := met_dPivLen
    wPiv        := met_wPivLen
    dMaxZones   := met_dMaxZones
    wMaxZones   := met_wMaxZones
    cloudFastL  := met_cloudFast
    cloudSlowL  := met_cloudSlow
    cloudProx   := met_cloudProx
    emaBufMul   := met_emaBuf
    tchCooldown := met_tchCooldown
    exhaustedAt := met_exhausted
    minRoundTch := met_minRoundTch
    roundIncr   := met_roundIncr
    retestWin   := met_retestWin
else if assetClass == "ENERGY"
    zoneHW      := ene_zoneHW
    zoneProxMul := ene_zoneProx
    dPiv        := ene_dPivLen
    wPiv        := ene_wPivLen
    dMaxZones   := ene_dMaxZones
    wMaxZones   := ene_wMaxZones
    cloudFastL  := ene_cloudFast
    cloudSlowL  := ene_cloudSlow
    cloudProx   := ene_cloudProx
    emaBufMul   := ene_emaBuf
    tchCooldown := ene_tchCooldown
    exhaustedAt := ene_exhausted
    minRoundTch := ene_minRoundTch
    roundIncr   := ene_roundIncr
    retestWin   := ene_retestWin
else if assetClass == "INDICES"
    zoneHW      := idx_zoneHW
    zoneProxMul := idx_zoneProx
    dPiv        := idx_dPivLen
    wPiv        := idx_wPivLen
    dMaxZones   := idx_dMaxZones
    wMaxZones   := idx_wMaxZones
    cloudFastL  := idx_cloudFast
    cloudSlowL  := idx_cloudSlow
    cloudProx   := idx_cloudProx
    emaBufMul   := idx_emaBuf
    tchCooldown := idx_tchCooldown
    exhaustedAt := idx_exhausted
    minRoundTch := idx_minRoundTch
    roundIncr   := idx_roundIncr
    retestWin   := idx_retestWin
else if assetClass == "CRYPTO"
    zoneHW      := cry_zoneHW
    zoneProxMul := cry_zoneProx
    dPiv        := cry_dPivLen
    wPiv        := cry_wPivLen
    dMaxZones   := cry_dMaxZones
    wMaxZones   := cry_wMaxZones
    cloudFastL  := cry_cloudFast
    cloudSlowL  := cry_cloudSlow
    cloudProx   := cry_cloudProx
    emaBufMul   := cry_emaBuf
    tchCooldown := cry_tchCooldown
    exhaustedAt := cry_exhausted
    minRoundTch := cry_minRoundTch
    roundIncr   := cry_roundIncr
    retestWin   := cry_retestWin
else if assetClass == "BONDS"
    zoneHW      := bnd_zoneHW
    zoneProxMul := bnd_zoneProx
    dPiv        := bnd_dPivLen
    wPiv        := bnd_wPivLen
    dMaxZones   := bnd_dMaxZones
    wMaxZones   := bnd_wMaxZones
    cloudFastL  := bnd_cloudFast
    cloudSlowL  := bnd_cloudSlow
    cloudProx   := bnd_cloudProx
    emaBufMul   := bnd_emaBuf
    tchCooldown := bnd_tchCooldown
    exhaustedAt := bnd_exhausted
    minRoundTch := bnd_minRoundTch
    roundIncr   := bnd_roundIncr
    retestWin   := bnd_retestWin

// ══════════════════════════════════════════════════════════════════════════════
// ATR + DERIVED SIZES
// ══════════════════════════════════════════════════════════════════════════════

// ══════════════════════════════════════════════════════════════════════════════

atr14       = ta.atr(14)
hw          = atr14 * zoneHW
zoneProxAbs = atr14 * zoneProxMul
cloudProxAbs = atr14 * cloudProx

// ══════════════════════════════════════════════════════════════════════════════
// EMA CLOUD + DIRECTION
// ══════════════════════════════════════════════════════════════════════════════

cloudFastE = ta.ema(close, cloudFastL)
cloudSlowE = ta.ema(close, cloudSlowL)
cloudLower = math.min(cloudFastE, cloudSlowE)
cloudUpper = math.max(cloudFastE, cloudSlowE)

ema9  = ta.ema(close, ema9Len)
ema21 = ta.ema(close, ema21Len)
ema50 = ta.ema(close, ema50Len)

bullStack = ema9 > ema21 and ema21 > ema50 and close > ema50
bearStack = ema9 < ema21 and ema21 < ema50 and close < ema50

cloudCol = bullStack ? cCloudBull : bearStack ? cCloudBear : cCloudNeut
cp1 = plot(cloudFastE, "Cloud Fast", color=na, editable=false)
cp2 = plot(cloudSlowE, "Cloud Slow", color=na, editable=false)
fill(cp1, cp2, color=showCloud ? cloudCol : na, title="EMA Cloud")

direction = ""
if dirMode == "LONG"
    direction := "LONG"
else if dirMode == "SHORT"
    direction := "SHORT"
else if bullStack
    direction := "LONG"
else if bearStack
    direction := "SHORT"
else
    direction := "NEUTRAL"

// ══════════════════════════════════════════════════════════════════════════════
// HTF SECURITY CALLS — must be top level in Pine v6
// ══════════════════════════════════════════════════════════════════════════════

dPH     = request.security(syminfo.tickerid, "D", ta.pivothigh(high, dPiv, dPiv))
dPL     = request.security(syminfo.tickerid, "D", ta.pivotlow(low,   dPiv, dPiv))
wPH     = request.security(syminfo.tickerid, "W", ta.pivothigh(high, wPiv, wPiv))
wPL     = request.security(syminfo.tickerid, "W", ta.pivotlow(low,   wPiv, wPiv))

pdHigh  = request.security(syminfo.tickerid, "D", high[1], lookahead=barmerge.lookahead_on)
pdLow   = request.security(syminfo.tickerid, "D", low[1],  lookahead=barmerge.lookahead_on)
pwHigh  = request.security(syminfo.tickerid, "W", high[1], lookahead=barmerge.lookahead_on)
pwLow   = request.security(syminfo.tickerid, "W", low[1],  lookahead=barmerge.lookahead_on)
ema200d = request.security(syminfo.tickerid, "D", ta.ema(close, 200))

// ══════════════════════════════════════════════════════════════════════════════
// USER DEFINED TYPE
// ══════════════════════════════════════════════════════════════════════════════

type Zone
    float  level
    float  top
    float  bot
    string src
    string srcType
    int    touches
    string strength
    bool   confluence
    string conflSrc

// ══════════════════════════════════════════════════════════════════════════════
// HELPER FUNCTIONS
// ══════════════════════════════════════════════════════════════════════════════

countTouches(zTop, zBot) =>
    count = 0
    lastTch = -tchCooldown - 1
    for i = 0 to tchLookback - 1
        if (i - lastTch) >= tchCooldown
            if low[i] <= zTop and high[i] >= zBot
                count += 1
                lastTch := i
    count

toStrength(t) =>
    if t >= exhaustedAt
        "EXHAUSTED"
    else if t >= 3
        "STRONG"
    else if t == 2
        "MODERATE"
    else
        "WEAK"

toLblSize(s) =>
    if s == "tiny"
        size.tiny
    else if s == "normal"
        size.normal
    else if s == "large"
        size.large
    else
        size.small

levelExists(arr, lvl, tol) =>
    found = false
    sz = array.size(arr)
    if sz > 0
        for k = 0 to sz - 1
            if math.abs(array.get(arr, k) - lvl) < tol
                found := true
                break
    found

// ══════════════════════════════════════════════════════════════════════════════
// BREAKOUT DETECTION — runs every bar
// ══════════════════════════════════════════════════════════════════════════════

var float  lastBrokenLvl = na
var int    lastBreakBar  = 0
var string lastBreakDir  = "NONE"
var string lastBreakType = "NONE"

breakState = "NONE"

if useBreakout
    // Break above PDH
    if not na(pdHigh) and close > pdHigh and close[1] <= pdHigh
        lastBrokenLvl := pdHigh
        lastBreakBar  := bar_index
        lastBreakDir  := "ABOVE"
        lastBreakType := "PDH"

    // Break above PWH
    if not na(pwHigh) and close > pwHigh and close[1] <= pwHigh
        lastBrokenLvl := pwHigh
        lastBreakBar  := bar_index
        lastBreakDir  := "ABOVE"
        lastBreakType := "PWH"

    // Break below PDL
    if not na(pdLow) and close < pdLow and close[1] >= pdLow
        lastBrokenLvl := pdLow
        lastBreakBar  := bar_index
        lastBreakDir  := "BELOW"
        lastBreakType := "PDL"

    // Break below PWL
    if not na(pwLow) and close < pwLow and close[1] >= pwLow
        lastBrokenLvl := pwLow
        lastBreakBar  := bar_index
        lastBreakDir  := "BELOW"
        lastBreakType := "PWL"

    // Evaluate active break
    if not na(lastBrokenLvl)
        barsFromBrk = bar_index - lastBreakBar
        proxAbs     = atr14 * retestProxMul
        falseThresh = atr14 * falseBreakMul

        if barsFromBrk > 0 and barsFromBrk <= retestWin
            if lastBreakDir == "ABOVE"
                retesting  = low  <= lastBrokenLvl + proxAbs and close >= lastBrokenLvl - proxAbs
                falseBreak = close < lastBrokenLvl - falseThresh
                if falseBreak
                    breakState    := "FALSE_BREAK"
                    lastBrokenLvl := float(na)
                else if retesting
                    breakState := "BREAKOUT_RETEST"
                else
                    breakState := "BREAKOUT_EXT"

            else if lastBreakDir == "BELOW"
                retesting  = high >= lastBrokenLvl - proxAbs and close <= lastBrokenLvl + proxAbs
                falseBreak = close > lastBrokenLvl + falseThresh
                if falseBreak
                    breakState    := "FALSE_BREAK"
                    lastBrokenLvl := float(na)
                else if retesting
                    breakState := "BREAKOUT_RETEST"
                else
                    breakState := "BREAKOUT_EXT"

        else if barsFromBrk > retestWin
            breakState    := "NONE"
            lastBrokenLvl := float(na)

// ══════════════════════════════════════════════════════════════════════════════
// ZONE COLLECTION + DRAWING — barstate.islast only
// ══════════════════════════════════════════════════════════════════════════════

// These are computed every bar for proximity grading
var float nearSuppLvl  = na
var string nearSuppName = "NONE"
var float nearResLvl   = na
var string nearResName  = "NONE"

// Per-bar level arrays for proximity checking (not just islast)
suppLvls  = array.new_float(0)
suppNames = array.new_string(0)
resLvls   = array.new_float(0)
resNames  = array.new_string(0)

addLevel(lvl, name) =>
    if not na(lvl)
        if lvl >= close
            array.push(resLvls, lvl)
            array.push(resNames, name)
        else
            array.push(suppLvls, lvl)
            array.push(suppNames, name)

if showPDH and not na(pdHigh)
    addLevel(pdHigh, "PDH")
if showPDL and not na(pdLow)
    addLevel(pdLow,  "PDL")
if showPWH and not na(pwHigh)
    addLevel(pwHigh, "PWH")
if showPWL and not na(pwLow)
    addLevel(pwLow,  "PWL")
if showEMA200 and not na(ema200d)
    addLevel(ema200d, "D.200EMA")

if showRound
    effectiveIncr = roundIncr > 0 ? roundIncr : (close > 5000.0 ? 100.0 : close > 500.0 ? 10.0 : close > 50.0 ? 1.0 : close > 5.0 ? 0.5 : close > 1.0 ? 0.01 : 0.001)
    base = math.floor(close / effectiveIncr) * effectiveIncr
    for i = -maxRounds to maxRounds
        lvl = base + i * effectiveIncr
        if math.abs(lvl - close) < atr14 * 15
            addLevel(lvl, "ROUND")

if showDSwings
    for i = 0 to dLookback - 1
        if not na(dPH[i])
            addLevel(dPH[i], "D.SwingH")
        if not na(dPL[i])
            addLevel(dPL[i], "D.SwingL")

if showWSwings
    for i = 0 to wLookback - 1
        if not na(wPH[i])
            addLevel(wPH[i], "W.SwingH")
        if not na(wPL[i])
            addLevel(wPL[i], "W.SwingL")

// Find nearest support and resistance
nearSuppLvl  := float(na)
nearSuppName := "NONE"
nearResLvl   := float(na)
nearResName  := "NONE"

if array.size(suppLvls) > 0
    for k = 0 to array.size(suppLvls) - 1
        lvl = array.get(suppLvls, k)
        if na(nearSuppLvl) or lvl > nearSuppLvl
            nearSuppLvl  := lvl
            nearSuppName := array.get(suppNames, k)

if array.size(resLvls) > 0
    for k = 0 to array.size(resLvls) - 1
        lvl = array.get(resLvls, k)
        if na(nearResLvl) or lvl < nearResLvl
            nearResLvl  := lvl
            nearResName := array.get(resNames, k)

// Proximity checks
suppDist    = na(nearSuppLvl) ? float(na) : close - nearSuppLvl
resDist     = na(nearResLvl)  ? float(na) : nearResLvl - close
suppDistAtr = na(suppDist)    ? float(na) : math.round(suppDist / atr14, 2)
resDistAtr  = na(resDist)     ? float(na) : math.round(resDist  / atr14, 2)

atSupp = not na(suppDist) and suppDist <= zoneProxAbs
atRes  = not na(resDist)  and resDist  <= zoneProxAbs

// Cloud proximity
inCloud       = close >= cloudLower and close <= cloudUpper
atCloudLower  = (close - cloudLower) >= -(cloudProxAbs * 0.5) and (close - cloudLower) <= cloudProxAbs * 2.0
atCloudUpper  = (cloudUpper - close) >= -(cloudProxAbs * 0.5) and (cloudUpper - close) <= cloudProxAbs * 2.0

cloudPos = "CLEAR"
cloudEdgeAtr = "na"

if direction == "LONG"
    dist = close - cloudLower
    cloudEdgeAtr := str.tostring(math.round(math.abs(dist) / atr14, 2))
    if inCloud
        cloudPos := "INSIDE_CLOUD"
    else if atCloudLower
        cloudPos := "AT_LOWER_EDGE"
    else if dist < 0
        cloudPos := "BELOW_CLOUD"
    else
        cloudPos := "CLEAR"
else if direction == "SHORT"
    dist = cloudUpper - close
    cloudEdgeAtr := str.tostring(math.round(math.abs(dist) / atr14, 2))
    if inCloud
        cloudPos := "INSIDE_CLOUD"
    else if atCloudUpper
        cloudPos := "AT_UPPER_EDGE"
    else if dist < 0
        cloudPos := "ABOVE_CLOUD"
    else
        cloudPos := "CLEAR"

atCloudEdge = false
if direction == "LONG"
    atCloudEdge := atCloudLower or inCloud
else if direction == "SHORT"
    atCloudEdge := atCloudUpper or inCloud

atCorrectZone = false
if direction == "LONG"
    atCorrectZone := atSupp
else if direction == "SHORT"
    atCorrectZone := atRes

atWrongZone = false
if direction == "LONG"
    atWrongZone := atRes
else if direction == "SHORT"
    atWrongZone := atSupp

nearZoneName = "NONE"
if direction == "LONG"
    if atSupp
        nearZoneName := nearSuppName
    else if atRes
        nearZoneName := nearResName
else if direction == "SHORT"
    if atRes
        nearZoneName := nearResName
    else if atSupp
        nearZoneName := nearSuppName

nearZoneDistAtr = "na"
if direction == "LONG" and atSupp
    nearZoneDistAtr := str.tostring(suppDistAtr)
else if direction == "SHORT" and atRes
    nearZoneDistAtr := str.tostring(resDistAtr)
suppDistStr     = na(suppDistAtr) ? "na" : str.tostring(suppDistAtr)
resDistStr      = na(resDistAtr)  ? "na" : str.tostring(resDistAtr)

// ── Grade ─────────────────────────────────────────────────────────────────────
grade = "WAIT"
if direction == "NEUTRAL"
    grade := "NO_DIRECTION"
else if breakState == "BREAKOUT_RETEST"
    grade := "BREAKOUT_RETEST"
else if breakState == "FALSE_BREAK"
    grade := "FALSE_BREAK"
else if breakState == "BREAKOUT_EXT"
    grade := "BREAKOUT_EXT"
else if atWrongZone
    grade := "OPPOSED"
else if atCorrectZone and atCloudEdge
    grade := "PRIME"
else if atCorrectZone
    grade := "AT_ZONE"
else if atCloudEdge and not inCloud
    grade := "AT_CLOUD"
else if inCloud
    grade := "IN_CLOUD"
else
    grade := "WAIT"

// ══════════════════════════════════════════════════════════════════════════════
// ZONE DRAWING — barstate.islast only
// ══════════════════════════════════════════════════════════════════════════════

if barstate.islast
    zones    = array.new<Zone>()
    seenH    = array.new_float(0)
    seenL    = array.new_float(0)

    if showPDH and not na(pdHigh)
        _t1 = pdHigh + hw
        _b1 = pdHigh - hw
        array.push(zones, Zone.new(pdHigh, _t1, _b1, "PDH", "prevday", countTouches(_t1,_b1), toStrength(countTouches(_t1,_b1)), false, ""))
    if showPDL and not na(pdLow)
        _t2 = pdLow + hw
        _b2 = pdLow - hw
        array.push(zones, Zone.new(pdLow, _t2, _b2, "PDL", "prevday", countTouches(_t2,_b2), toStrength(countTouches(_t2,_b2)), false, ""))
    if showPWH and not na(pwHigh)
        _t3 = pwHigh + hw
        _b3 = pwHigh - hw
        array.push(zones, Zone.new(pwHigh, _t3, _b3, "PWH", "prevweek", countTouches(_t3,_b3), toStrength(countTouches(_t3,_b3)), false, ""))
    if showPWL and not na(pwLow)
        _t4 = pwLow + hw
        _b4 = pwLow - hw
        array.push(zones, Zone.new(pwLow, _t4, _b4, "PWL", "prevweek", countTouches(_t4,_b4), toStrength(countTouches(_t4,_b4)), false, ""))

    if showEMA200 and not na(ema200d)
        emaBufAbs = atr14 * emaBufMul
        t  = ema200d + emaBufAbs
        b  = ema200d - emaBufAbs
        tc = countTouches(t, b)
        array.push(zones, Zone.new(ema200d, t, b, "D.200EMA", "ema200", tc, toStrength(tc), false, ""))

    if showRound
        effectiveIncr = roundIncr > 0 ? roundIncr : (close > 5000.0 ? 100.0 : close > 500.0 ? 10.0 : close > 50.0 ? 1.0 : close > 5.0 ? 0.5 : close > 1.0 ? 0.01 : 0.001)
        roundHW = atr14 * 0.35
        base = math.floor(close / effectiveIncr) * effectiveIncr
        for i = -maxRounds to maxRounds
            lvl = base + i * effectiveIncr
            if math.abs(lvl - close) < atr14 * 15
                t  = lvl + roundHW
                b  = lvl - roundHW
                tc = countTouches(t, b)
                if tc >= minRoundTch
                    lbl = "RND " + str.tostring(math.round(lvl / syminfo.mintick) * syminfo.mintick, format.mintick)
                    array.push(zones, Zone.new(lvl, t, b, lbl, "round", tc, toStrength(tc), false, ""))

    if showDSwings
        dHC = 0
        dLC = 0
        for i = 0 to dLookback - 1
            if not na(dPH[i]) and dHC < dMaxZones
                lvl = dPH[i]
                if not levelExists(seenH, lvl, hw)
                    array.push(seenH, lvl)
                    _ts = lvl + hw
                    _bs = lvl - hw
                    array.push(zones, Zone.new(lvl, _ts, _bs, "D.SwingH", "daily", countTouches(_ts,_bs), toStrength(countTouches(_ts,_bs)), false, ""))
                    dHC += 1
            if not na(dPL[i]) and dLC < dMaxZones
                lvl = dPL[i]
                if not levelExists(seenL, lvl, hw)
                    array.push(seenL, lvl)
                    _ts = lvl + hw
                    _bs = lvl - hw
                    array.push(zones, Zone.new(lvl, _ts, _bs, "D.SwingL", "daily", countTouches(_ts,_bs), toStrength(countTouches(_ts,_bs)), false, ""))
                    dLC += 1

    if showWSwings
        wHC = 0
        wLC = 0
        for i = 0 to wLookback - 1
            if not na(wPH[i]) and wHC < wMaxZones
                lvl = wPH[i]
                if not levelExists(seenH, lvl, hw)
                    array.push(seenH, lvl)
                    _ts = lvl + hw
                    _bs = lvl - hw
                    array.push(zones, Zone.new(lvl, _ts, _bs, "W.SwingH", "weekly", countTouches(_ts,_bs), toStrength(countTouches(_ts,_bs)), false, ""))
                    wHC += 1
            if not na(wPL[i]) and wLC < wMaxZones
                lvl = wPL[i]
                if not levelExists(seenL, lvl, hw)
                    array.push(seenL, lvl)
                    _ts = lvl + hw
                    _bs = lvl - hw
                    array.push(zones, Zone.new(lvl, _ts, _bs, "W.SwingL", "weekly", countTouches(_ts,_bs), toStrength(countTouches(_ts,_bs)), false, ""))
                    wLC += 1

    // Confluence detection
    n = array.size(zones)
    if n >= 2
        for i = 0 to n - 2
            zi = array.get(zones, i)
            for j = i + 1 to n - 1
                zj = array.get(zones, j)
                if zi.bot <= zj.top and zi.top >= zj.bot
                    if not zi.confluence
                        zi.confluence := true
                        zi.conflSrc   := zj.src
                    else
                        zi.conflSrc := zi.conflSrc + "+" + zj.src
                    if not zj.confluence
                        zj.confluence := true
                        zj.conflSrc   := zi.src
                    else
                        zj.conflSrc := zj.conflSrc + "+" + zi.src

    // Draw zones
    if array.size(zones) > 0
        for i = 0 to array.size(zones) - 1
            z = array.get(zones, i)

            baseCol = switch z.srcType
                "weekly"   => cWeekly
                "daily"    => cDaily
                "prevday"  => cPrevDay
                "prevweek" => cPrevWeek
                "round"    => cRound
                "ema200"   => cEMA
                => color.gray

            drawCol   = z.strength == "EXHAUSTED" ? cExhausted : z.confluence ? cConfluence : baseCol
            bgCol     = color.new(drawCol, 78)
            borderCol = color.new(drawCol, 15)
            borderWid = z.strength == "STRONG" or z.strength == "EXHAUSTED" or z.confluence ? 2 : 1

            box.new(bar_index - tchLookback, z.top, bar_index + extRight, z.bot,
                border_color=borderCol, bgcolor=bgCol, border_width=borderWid)

            if showLbls
                strTag   = z.strength == "EXHAUSTED" ? " [EXH]" : z.strength == "STRONG" ? " [STR]" : z.strength == "MODERATE" ? " [MOD]" : " [WK]"
                conflTag = z.confluence ? " [C+" + z.conflSrc + "]" : ""
                tTxt     = " T:" + str.tostring(z.touches)
                lblTxt   = z.src + tTxt + strTag + conflTag

                label.new(bar_index + extRight + 1, z.level, lblTxt,
                    style=label.style_label_left,
                    color=color.new(drawCol, 55),
                    textcolor=color.white,
                    size=toLblSize(lblSize))

    // Grade label
    if showGradeLbl
        gCol = color.new(#444444, 30)
        if grade == "PRIME" or grade == "BREAKOUT_RETEST"
            gCol := color.new(#FFD700, 10)
        else if grade == "AT_ZONE" or grade == "AT_CLOUD"
            gCol := color.new(#00C853, 20)
        else if grade == "OPPOSED" or grade == "FALSE_BREAK"
            gCol := color.new(#FF1744, 20)
        else if grade == "BREAKOUT_EXT"
            gCol := color.new(#FF8C00, 20)

        clsTag  = showDetected ? " [" + assetClass + "]" : ""
        zoneInf = nearZoneName != "NONE" ? " | " + nearZoneName + " (" + nearZoneDistAtr + " ATR)" : ""
        cldInf  = cloudPos != "CLEAR"    ? " | Cloud: " + cloudPos : ""
        brkInf  = breakState != "NONE"   ? " | BRK: " + breakState : ""
        lblTxt  = "[FCC-SRL]" + clsTag + " " + direction + " | " + grade + zoneInf + cldInf + brkInf

        label.new(bar_index, high + atr14 * 0.5, lblTxt,
            style=label.style_label_down,
            color=gCol,
            textcolor=color.white,
            size=size.small)

// ══════════════════════════════════════════════════════════════════════════════
// WEBHOOK — fires every confirmed bar close
// ══════════════════════════════════════════════════════════════════════════════

var string lastGrade = ""
gradeChanged = grade != lastGrade
lastGrade   := grade

shouldAlert = alertEveryBar ? barstate.isconfirmed : (barstate.isconfirmed and gradeChanged)

if shouldAlert
    jsonMsg = '{"pair":"'           + syminfo.ticker   + '"' +
              ',"asset_class":"'    + assetClass        + '"' +
              ',"direction":"'      + direction          + '"' +
              ',"grade":"'          + grade              + '"' +
              ',"zone":"'           + nearZoneName       + '"' +
              ',"zone_dist_atr":"'  + nearZoneDistAtr    + '"' +
              ',"cloud_pos":"'      + cloudPos           + '"' +
              ',"cloud_dist_atr":"' + cloudEdgeAtr       + '"' +
              ',"breakout":"'       + breakState         + '"' +
              ',"supp_name":"'      + nearSuppName       + '"' +
              ',"supp_dist_atr":"'  + suppDistStr        + '"' +
              ',"res_name":"'       + nearResName        + '"' +
              ',"res_dist_atr":"'   + resDistStr         + '"' +
              '}'
    alert(jsonMsg, alert.freq_once_per_bar_close)
