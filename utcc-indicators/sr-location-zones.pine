//@version=6
// ══════════════════════════════════════════════════════════════════════════════
// HTF S/R Location Zones — v1.0.0
// Part of the Forex Command Centre indicator suite
// Designed for 4H chart (recommended). Works on 1H and Daily.
//
// Sources:
//   - Weekly swing highs/lows (HTF structure)
//   - Daily swing highs/lows (medium-term structure)
//   - Previous Day High/Low (PDH/PDL)
//   - Previous Week High/Low (PWH/PWL)
//   - Psychological round numbers (auto-detected or manual)
//   - Daily 200 EMA zone (institutional reference)
//
// Zone strength scored by touch count:
//   WEAK = 1 touch | MODERATE = 2 | STRONG = 3+ | EXHAUSTED = configurable
//
// Confluence flagged when 2+ sources overlap within zone width.
// ══════════════════════════════════════════════════════════════════════════════

indicator("HTF S/R Location Zones", shorttitle="HTF-SR", overlay=true,
     max_boxes_count=200, max_labels_count=200, max_lines_count=10)

// ══════════════════════════════════════════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════════════════════════════════════════

// ─── Swing Structure ─────────────────────────────────────────────────────────
grpSW = "Swing Structure (Daily & Weekly)"

showDSwings = input.bool(true, "Show Daily Swings", group=grpSW)
dPivLen     = input.int(5, "Daily Pivot Strength (bars each side)", group=grpSW,
               minval=2, maxval=15,
               tooltip="Higher = fewer but stronger confirmed swings. 5 = pivot must be the highest/lowest over 5 daily bars each side.")
dLookback   = input.int(500, "Daily Swing Search Depth (current TF bars)", group=grpSW,
               minval=50, maxval=1500,
               tooltip="On 4H chart: 500 bars = ~83 days. On 1H: 500 bars = ~21 days. Increase if you want older swings.")
dMaxZones   = input.int(6, "Max Daily Swing Zones (each direction)", group=grpSW,
               minval=1, maxval=15,
               tooltip="Max swing highs + max swing lows to draw. Total daily zones = 2x this number.")

showWSwings = input.bool(true, "Show Weekly Swings", group=grpSW)
wPivLen     = input.int(3, "Weekly Pivot Strength (bars each side)", group=grpSW,
               minval=1, maxval=8,
               tooltip="Higher = fewer but stronger weekly swings confirmed.")
wLookback   = input.int(500, "Weekly Swing Search Depth (current TF bars)", group=grpSW,
               minval=50, maxval=1500,
               tooltip="On 4H chart: 500 bars = ~83 days (~12 weeks). On 1H: 500 bars = ~21 days (~3 weeks).")
wMaxZones   = input.int(4, "Max Weekly Swing Zones (each direction)", group=grpSW,
               minval=1, maxval=10)

// ─── Previous Day / Week ─────────────────────────────────────────────────────
grpPD = "Previous Day / Week Levels"

showPDH = input.bool(true, "Previous Day High (PDH)", group=grpPD)
showPDL = input.bool(true, "Previous Day Low (PDL)",  group=grpPD)
showPWH = input.bool(true, "Previous Week High (PWH)", group=grpPD)
showPWL = input.bool(true, "Previous Week Low (PWL)",  group=grpPD)

// ─── Round Numbers ────────────────────────────────────────────────────────────
grpRN = "Psychological Round Numbers"

showRound   = input.bool(true, "Show Round Numbers", group=grpRN)
customIncr  = input.float(0.0, "Custom Increment (0 = auto-detect)", group=grpRN,
               minval=0, step=0.0001,
               tooltip="Leave at 0 for auto. Manual examples: 0.01 = 100-pip levels on majors, 0.001 = 10-pip, 0.5 = indices, 50.0 = S&P500")
maxRounds   = input.int(4, "Levels Above & Below Price", group=grpRN,
               minval=1, maxval=10,
               tooltip="Number of round levels to draw above and below current price.")
minRoundTch = input.int(1, "Min Touches to Display", group=grpRN,
               minval=0, maxval=5,
               tooltip="0 = show all round numbers regardless of history. 1 = only show if price has actually touched that level. Recommended: 1.")
roundBufMul = input.float(0.4, "Round Number Zone Width (ATR x)", group=grpRN,
               minval=0.1, maxval=1.5, step=0.1,
               tooltip="Buffer above/below the round number price to form the zone box.")

// ─── 200 EMA ─────────────────────────────────────────────────────────────────
grpEMA = "Daily 200 EMA Zone"

showEMA200 = input.bool(true, "Show Daily 200 EMA Zone", group=grpEMA,
              tooltip="Creates a zone around the Daily 200 EMA. One of the most watched institutional levels.")
emaBufMul  = input.float(0.5, "EMA Zone Width (ATR x)", group=grpEMA,
              minval=0.1, maxval=3.0, step=0.1,
              tooltip="How wide the EMA zone is. Wider = higher tolerance for EMA reactions.")

// ─── Zone Appearance ─────────────────────────────────────────────────────────
grpVis = "Zone Appearance"

zoneHW      = input.float(0.3, "Zone Half-Width (ATR x)", group=grpVis,
               minval=0.05, maxval=1.5, step=0.05,
               tooltip="Each zone extends this amount above and below the level. Total zone height = 2x this value x ATR.")
showLbls    = input.bool(true, "Show Labels", group=grpVis)
lblSize     = input.string("small", "Label Size", group=grpVis,
               options=["tiny", "small", "normal", "large"])
extRight    = input.int(20, "Extend Boxes Right (bars)", group=grpVis,
               minval=0, maxval=200,
               tooltip="How far right the zone boxes extend beyond the current bar. Gives forward visibility.")

// ─── Colours ─────────────────────────────────────────────────────────────────
grpC = "Colours"

cWeekly     = input.color(color.new(#FF3366, 20), "Weekly Swing",             group=grpC)
cDaily      = input.color(color.new(#FF8C00, 25), "Daily Swing",              group=grpC)
cPrevDay    = input.color(color.new(#00BFFF, 25), "Prev Day H/L",             group=grpC)
cPrevWeek   = input.color(color.new(#9370DB, 25), "Prev Week H/L",            group=grpC)
cRound      = input.color(color.new(#20C997, 35), "Round Numbers",            group=grpC)
cEMA        = input.color(color.new(#FFD700, 35), "Daily 200 EMA",            group=grpC)
cConfluence = input.color(color.new(#FF4444, 10), "Confluence (2+ sources)",  group=grpC)
cExhausted  = input.color(color.new(#888888, 45), "Exhausted Zone",           group=grpC)

// ─── Touch Count & Strength ───────────────────────────────────────────────────
grpT = "Touch Count & Zone Strength"

tchLookback = input.int(300, "Touch Count Lookback (bars)", group=grpT,
               minval=50, maxval=1000,
               tooltip="How many current TF bars back to count price touches for zone strength rating.")
tchCooldown = input.int(3, "Touch Cooldown (bars)", group=grpT,
               minval=1, maxval=30,
               tooltip="Minimum bars between counted touches. Prevents one move counting as multiple touches. On 4H: 3 bars = 12 hours.")
exhaustedAt = input.int(4, "Exhausted Threshold (touches)", group=grpT,
               minval=2, maxval=10,
               tooltip="Zone flagged EXHAUSTED at this many touches. Signals the level is over-tested and may be about to break. Treat with caution.")

// ─── Alerts ───────────────────────────────────────────────────────────────────
grpAlt = "Alerts"

altAnyZone    = input.bool(true, "Alert: Price Enters Any Zone",          group=grpAlt)
altConfluence = input.bool(true, "Alert: Price Enters Confluence Zone",   group=grpAlt)
altExhausted  = input.bool(true, "Alert: Price at Exhausted Zone",        group=grpAlt)

// ══════════════════════════════════════════════════════════════════════════════
// ATR (used for zone sizing throughout)
// ══════════════════════════════════════════════════════════════════════════════

atr14 = ta.atr(14)
hw    = atr14 * zoneHW   // zone half-width in price units

// ══════════════════════════════════════════════════════════════════════════════
// HTF DATA — all request.security calls MUST be at top level
// ══════════════════════════════════════════════════════════════════════════════

// Daily pivot series (computed on daily chart, mapped back to current TF)
dPH = request.security(syminfo.tickerid, "D", ta.pivothigh(high, dPivLen, dPivLen))
dPL = request.security(syminfo.tickerid, "D", ta.pivotlow(low,  dPivLen, dPivLen))

// Weekly pivot series
wPH = request.security(syminfo.tickerid, "W", ta.pivothigh(high, wPivLen, wPivLen))
wPL = request.security(syminfo.tickerid, "W", ta.pivotlow(low,  wPivLen, wPivLen))

// Previous day H/L (lookahead_on = use previous completed bar value)
pdHigh = request.security(syminfo.tickerid, "D", high[1], lookahead=barmerge.lookahead_on)
pdLow  = request.security(syminfo.tickerid, "D", low[1],  lookahead=barmerge.lookahead_on)

// Previous week H/L
pwHigh = request.security(syminfo.tickerid, "W", high[1], lookahead=barmerge.lookahead_on)
pwLow  = request.security(syminfo.tickerid, "W", low[1],  lookahead=barmerge.lookahead_on)

// Daily 200 EMA
ema200d = request.security(syminfo.tickerid, "D", ta.ema(close, 200))

// ══════════════════════════════════════════════════════════════════════════════
// USER DEFINED TYPE
// ══════════════════════════════════════════════════════════════════════════════

type Zone
    float  level       // Centre price of the zone
    float  top         // Upper boundary
    float  bot         // Lower boundary
    string src         // Display source name (e.g. "PDH", "W.SwingH")
    string srcType     // Internal type key for colour lookup
    int    touches     // Touch count from countTouches()
    string strength    // "WEAK" | "MODERATE" | "STRONG" | "EXHAUSTED"
    bool   confluence  // True when overlapping with another zone
    string conflSrc    // Names of other overlapping sources

// ══════════════════════════════════════════════════════════════════════════════
// HELPER FUNCTIONS
// ══════════════════════════════════════════════════════════════════════════════

// Count how many times price entered the zone within the lookback window.
// Cooldown prevents the same move being counted multiple times.
countTouches(zTop, zBot) =>
    count = 0
    lastTch = -tchCooldown - 1
    for i = 0 to tchLookback - 1
        if (i - lastTch) >= tchCooldown
            if low[i] <= zTop and high[i] >= zBot
                count += 1
                lastTch := i
    count

// Convert touch count to strength string
toStrength(t) =>
    if t >= exhaustedAt
        "EXHAUSTED"
    else if t >= 3
        "STRONG"
    else if t == 2
        "MODERATE"
    else
        "WEAK"

// Map string label size to Pine constant
toLblSize(s) =>
    if s == "tiny"
        size.tiny
    else if s == "normal"
        size.normal
    else if s == "large"
        size.large
    else
        size.small

// Auto-detect round number increment from current price
autoIncrement() =>
    p = close
    if p > 5000.0
        100.0
    else if p > 500.0
        10.0
    else if p > 50.0
        1.0
    else if p > 5.0
        0.5
    else if p > 1.0
        0.01
    else
        0.001

// Check if a level already exists in a float array (within tolerance)
levelExists(arr, lvl, tol) =>
    found = false
    sz = array.size(arr)
    for k = 0 to sz - 1
        if math.abs(array.get(arr, k) - lvl) < tol
            found := true
            break
    found

// ══════════════════════════════════════════════════════════════════════════════
// MAIN — zone collection and drawing on last bar only
// Restricting to barstate.islast prevents thousands of boxes being created
// on historical bars and keeps the chart clean.
// ══════════════════════════════════════════════════════════════════════════════

if barstate.islast

    zones = array.new<Zone>()

    // Deduplication registry: tracks price levels already added to avoid
    // the same HTF pivot appearing multiple times across intraday bars
    seenHighs = array.new_float(0)
    seenLows  = array.new_float(0)

    // ─── Previous Day High ─────────────────────────────────────────────────
    if showPDH and not na(pdHigh)
        t  = pdHigh + hw
        b  = pdHigh - hw
        tc = countTouches(t, b)
        array.push(zones, Zone.new(pdHigh, t, b, "PDH", "prevday", tc, toStrength(tc), false, ""))

    // ─── Previous Day Low ──────────────────────────────────────────────────
    if showPDL and not na(pdLow)
        t  = pdLow + hw
        b  = pdLow - hw
        tc = countTouches(t, b)
        array.push(zones, Zone.new(pdLow, t, b, "PDL", "prevday", tc, toStrength(tc), false, ""))

    // ─── Previous Week High ────────────────────────────────────────────────
    if showPWH and not na(pwHigh)
        t  = pwHigh + hw
        b  = pwHigh - hw
        tc = countTouches(t, b)
        array.push(zones, Zone.new(pwHigh, t, b, "PWH", "prevweek", tc, toStrength(tc), false, ""))

    // ─── Previous Week Low ─────────────────────────────────────────────────
    if showPWL and not na(pwLow)
        t  = pwLow + hw
        b  = pwLow - hw
        tc = countTouches(t, b)
        array.push(zones, Zone.new(pwLow, t, b, "PWL", "prevweek", tc, toStrength(tc), false, ""))

    // ─── Daily 200 EMA ─────────────────────────────────────────────────────
    if showEMA200 and not na(ema200d)
        emaBufAbs = atr14 * emaBufMul
        t  = ema200d + emaBufAbs
        b  = ema200d - emaBufAbs
        tc = countTouches(t, b)
        array.push(zones, Zone.new(ema200d, t, b, "D.200EMA", "ema200", tc, toStrength(tc), false, ""))

    // ─── Round Numbers ─────────────────────────────────────────────────────
    if showRound
        incr        = customIncr > 0 ? customIncr : autoIncrement()
        roundHW     = atr14 * roundBufMul
        baseLevel   = math.floor(close / incr) * incr
        maxDistAtr  = atr14 * 15  // only show round numbers within 15 ATR of price

        for i = -maxRounds to maxRounds
            lvl = baseLevel + i * incr
            if math.abs(lvl - close) < maxDistAtr
                t  = lvl + roundHW
                b  = lvl - roundHW
                tc = countTouches(t, b)
                if tc >= minRoundTch
                    lbl = "RND " + str.tostring(math.round(lvl / syminfo.mintick) * syminfo.mintick, format.mintick)
                    array.push(zones, Zone.new(lvl, t, b, lbl, "round", tc, toStrength(tc), false, ""))

    // ─── Daily Swing Highs/Lows ────────────────────────────────────────────
    if showDSwings
        dHCount = 0
        dLCount = 0

        for i = 0 to dLookback - 1
            // Daily Swing Highs
            if not na(dPH[i]) and dHCount < dMaxZones
                lvl = dPH[i]
                if not levelExists(seenHighs, lvl, hw)
                    array.push(seenHighs, lvl)
                    t  = lvl + hw
                    b  = lvl - hw
                    tc = countTouches(t, b)
                    array.push(zones, Zone.new(lvl, t, b, "D.SwingH", "daily", tc, toStrength(tc), false, ""))
                    dHCount += 1

            // Daily Swing Lows
            if not na(dPL[i]) and dLCount < dMaxZones
                lvl = dPL[i]
                if not levelExists(seenLows, lvl, hw)
                    array.push(seenLows, lvl)
                    t  = lvl + hw
                    b  = lvl - hw
                    tc = countTouches(t, b)
                    array.push(zones, Zone.new(lvl, t, b, "D.SwingL", "daily", tc, toStrength(tc), false, ""))
                    dLCount += 1

    // ─── Weekly Swing Highs/Lows ───────────────────────────────────────────
    if showWSwings
        wHCount = 0
        wLCount = 0

        for i = 0 to wLookback - 1
            // Weekly Swing Highs
            if not na(wPH[i]) and wHCount < wMaxZones
                lvl = wPH[i]
                if not levelExists(seenHighs, lvl, hw)
                    array.push(seenHighs, lvl)
                    t  = lvl + hw
                    b  = lvl - hw
                    tc = countTouches(t, b)
                    array.push(zones, Zone.new(lvl, t, b, "W.SwingH", "weekly", tc, toStrength(tc), false, ""))
                    wHCount += 1

            // Weekly Swing Lows
            if not na(wPL[i]) and wLCount < wMaxZones
                lvl = wPL[i]
                if not levelExists(seenLows, lvl, hw)
                    array.push(seenLows, lvl)
                    t  = lvl + hw
                    b  = lvl - hw
                    tc = countTouches(t, b)
                    array.push(zones, Zone.new(lvl, t, b, "W.SwingL", "weekly", tc, toStrength(tc), false, ""))
                    wLCount += 1

    // ─── Confluence Detection ──────────────────────────────────────────────
    // Any two zones whose boxes overlap are marked as confluence.
    // The zone with fewer sources inherits the other's name.
    n = array.size(zones)
    for i = 0 to n - 2
        zi = array.get(zones, i)
        for j = i + 1 to n - 1
            zj = array.get(zones, j)
            overlaps = zi.bot <= zj.top and zi.top >= zj.bot
            if overlaps
                if not zi.confluence
                    zi.confluence := true
                    zi.conflSrc   := zj.src
                else
                    zi.conflSrc := zi.conflSrc + "+" + zj.src
                if not zj.confluence
                    zj.confluence := true
                    zj.conflSrc   := zi.src
                else
                    zj.conflSrc := zj.conflSrc + "+" + zi.src

    // ─── Draw All Zones ────────────────────────────────────────────────────
    for i = 0 to array.size(zones) - 1
        z = array.get(zones, i)

        // Select base colour by source type
        baseCol = switch z.srcType
            "weekly"   => cWeekly
            "daily"    => cDaily
            "prevday"  => cPrevDay
            "prevweek" => cPrevWeek
            "round"    => cRound
            "ema200"   => cEMA
            => color.gray

        // Override colour for special states
        drawCol = z.strength == "EXHAUSTED" ? cExhausted :
                  z.confluence             ? cConfluence : baseCol

        bgCol     = color.new(drawCol, 78)
        borderCol = color.new(drawCol, 15)
        borderWid = z.strength == "STRONG" or z.strength == "EXHAUSTED" or z.confluence ? 2 : 1

        // Draw zone box
        box.new(
            bar_index - tchLookback,
            z.top,
            bar_index + extRight,
            z.bot,
            border_color = borderCol,
            bgcolor       = bgCol,
            border_width  = borderWid)

        // Draw label on right edge
        if showLbls
            strTag = z.strength == "EXHAUSTED" ? " [EXHAUSTED]" :
                     z.strength == "STRONG"     ? " [STRONG]"    :
                     z.strength == "MODERATE"   ? " [MOD]"       : " [WEAK]"

            conflTag = z.confluence ? " [CONFL+" + z.conflSrc + "]" : ""
            tTxt     = " T:" + str.tostring(z.touches)
            lblTxt   = z.src + tTxt + strTag + conflTag

            label.new(
                bar_index + extRight + 1,
                z.level,
                lblTxt,
                style     = label.style_label_left,
                color     = color.new(drawCol, 55),
                textcolor = color.white,
                size      = toLblSize(lblSize))

// ══════════════════════════════════════════════════════════════════════════════
// ALERTS — must run on every bar (not inside barstate.islast)
// Only PDH/PDL, PWH/PWL and EMA used here. Swing zone alerts require
// manual alert conditions in TradingView alert dialogue.
// ══════════════════════════════════════════════════════════════════════════════

inZ(lvl, buf) => not na(lvl) and low <= lvl + buf and high >= lvl - buf

pdh_hit  = showPDH  and inZ(pdHigh,  hw)
pdl_hit  = showPDL  and inZ(pdLow,   hw)
pwh_hit  = showPWH  and inZ(pwHigh,  hw)
pwl_hit  = showPWL  and inZ(pwLow,   hw)
ema_hit  = showEMA200 and inZ(ema200d, atr14 * emaBufMul)

anyZone     = pdh_hit or pdl_hit or pwh_hit or pwl_hit or ema_hit
conflHit    = ema_hit and (pdh_hit or pdl_hit or pwh_hit or pwl_hit)

if altAnyZone and anyZone
    alert("HTF-SR | " + syminfo.ticker + " | Price entering key S/R zone", alert.freq_once_per_bar_close)

if altConfluence and conflHit
    alert("HTF-SR CONFLUENCE | " + syminfo.ticker + " | HIGH PRIORITY: Multiple zones stacked at current price", alert.freq_once_per_bar_close)

// ══════════════════════════════════════════════════════════════════════════════
// LEGEND LINE (optional visual reference)
// ══════════════════════════════════════════════════════════════════════════════
// No plot output needed — this is a pure overlay box/label indicator.
// Colours are explained fully in the label tags on each zone.
