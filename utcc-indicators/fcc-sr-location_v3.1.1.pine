// ══════════════════════════════════════════════════════════════════════════════
// RESOLVE ACTIVE PROFILE
// ══════════════════════════════════════════════════════════════════════════════

zoneHW      = fx_zoneHW
zoneProxMul = fx_zoneProx
dPiv        = fx_dPivLen
wPiv        = fx_wPivLen
dMaxZones   = fx_dMaxZones
wMaxZones   = fx_wMaxZones
cloudFastL  = fx_cloudFast
cloudSlowL  = fx_cloudSlow
cloudProx   = fx_cloudProx
emaBufMul   = fx_emaBuf
tchCooldown = fx_tchCooldown
exhaustedAt = fx_exhausted
minRoundTch = fx_minRoundTch
roundIncr   = fx_roundIncr

// JPY pair auto-detect: if auto (0) and ticker contains JPY as quote, use 1.0
_isJPYQuote = str.endswith(_t, "JPY")
if roundIncr == 0.0 and _isJPYQuote
    roundIncr := 1.0
retestWin   = fx_retestWin
mergeGap    = fx_mergeGap

if assetClass == "METALS"
    zoneHW      := met_zoneHW
    zoneProxMul := met_zoneProx
    dPiv        := met_dPivLen
    wPiv        := met_wPivLen
    dMaxZones   := met_dMaxZones
    wMaxZones   := met_wMaxZones
    cloudFastL  := met_cloudFast
    cloudSlowL  := met_cloudSlow
    cloudProx   := met_cloudProx
    emaBufMul   := met_emaBuf
    tchCooldown := met_tchCooldown
    exhaustedAt := met_exhausted
    minRoundTch := met_minRoundTch
    roundIncr   := met_roundIncr
    retestWin   := met_retestWin
    mergeGap    := met_mergeGap
else if assetClass == "ENERGY"
    zoneHW      := ene_zoneHW
    zoneProxMul := ene_zoneProx
    dPiv        := ene_dPivLen
    wPiv        := ene_wPivLen
    dMaxZones   := ene_dMaxZones
    wMaxZones   := ene_wMaxZones
    cloudFastL  := ene_cloudFast
    cloudSlowL  := ene_cloudSlow
    cloudProx   := ene_cloudProx
    emaBufMul   := ene_emaBuf
    tchCooldown := ene_tchCooldown
    exhaustedAt := ene_exhausted
    minRoundTch := ene_minRoundTch
    roundIncr   := ene_roundIncr
    retestWin   := ene_retestWin
    mergeGap    := ene_mergeGap
else if assetClass == "INDICES"
    zoneHW      := idx_zoneHW
    zoneProxMul := idx_zoneProx
    dPiv        := idx_dPivLen
    wPiv        := idx_wPivLen
    dMaxZones   := idx_dMaxZones
    wMaxZones   := idx_wMaxZones
    cloudFastL  := idx_cloudFast
    cloudSlowL  := idx_cloudSlow
    cloudProx   := idx_cloudProx
    emaBufMul   := idx_emaBuf
    tchCooldown := idx_tchCooldown
    exhaustedAt := idx_exhausted
    minRoundTch := idx_minRoundTch
    roundIncr   := idx_roundIncr
    retestWin   := idx_retestWin
    mergeGap    := idx_mergeGap
else if assetClass == "CRYPTO"
    zoneHW      := cry_zoneHW
    zoneProxMul := cry_zoneProx
    dPiv        := cry_dPivLen
    wPiv        := cry_wPivLen
    dMaxZones   := cry_dMaxZones
    wMaxZones   := cry_wMaxZones
    cloudFastL  := cry_cloudFast
    cloudSlowL  := cry_cloudSlow
    cloudProx   := cry_cloudProx
    emaBufMul   := cry_emaBuf
    tchCooldown := cry_tchCooldown
    exhaustedAt := cry_exhausted
    minRoundTch := cry_minRoundTch
    roundIncr   := cry_roundIncr
    retestWin   := cry_retestWin
    mergeGap    := cry_mergeGap
else if assetClass == "BONDS"
    zoneHW      := bnd_zoneHW
    zoneProxMul := bnd_zoneProx
    dPiv        := bnd_dPivLen
    wPiv        := bnd_wPivLen
    dMaxZones   := bnd_dMaxZones
    wMaxZones   := bnd_wMaxZones
    cloudFastL  := bnd_cloudFast
    cloudSlowL  := bnd_cloudSlow
    cloudProx   := bnd_cloudProx
    emaBufMul   := bnd_emaBuf
    tchCooldown := bnd_tchCooldown
    exhaustedAt := bnd_exhausted
    minRoundTch := bnd_minRoundTch
    roundIncr   := bnd_roundIncr
    retestWin   := bnd_retestWin
    mergeGap    := bnd_mergeGap

// ══════════════════════════════════════════════════════════════════════════════
// ATR + DERIVED SIZES
// ══════════════════════════════════════════════════════════════════════════════

// ══════════════════════════════════════════════════════════════════════════════

atr14       = ta.atr(14)
hw          = atr14 * zoneHW
zoneProxAbs = atr14 * zoneProxMul
cloudProxAbs = atr14 * cloudProx

// ══════════════════════════════════════════════════════════════════════════════
// EMA CLOUD + DIRECTION
// ══════════════════════════════════════════════════════════════════════════════

cloudFastE = ta.ema(close, cloudFastL)
cloudSlowE = ta.ema(close, cloudSlowL)
cloudLower = math.min(cloudFastE, cloudSlowE)
cloudUpper = math.max(cloudFastE, cloudSlowE)

ema9  = ta.ema(close, ema9Len)
ema21 = ta.ema(close, ema21Len)
ema50 = ta.ema(close, ema50Len)

bullStack = ema9 > ema21 and ema21 > ema50 and close > ema50
bearStack = ema9 < ema21 and ema21 < ema50 and close < ema50

cloudCol = bullStack ? cCloudBull : bearStack ? cCloudBear : cCloudNeut
cp1 = plot(cloudFastE, "Cloud Fast", color=na, editable=false)
cp2 = plot(cloudSlowE, "Cloud Slow", color=na, editable=false)
fill(cp1, cp2, color=showCloud ? cloudCol : na, title="EMA Cloud")

direction = ""
if dirMode == "LONG"
    direction := "LONG"
else if dirMode == "SHORT"
    direction := "SHORT"
else if bullStack
    direction := "LONG"
else if bearStack
    direction := "SHORT"
else
    direction := "NEUTRAL"

// ══════════════════════════════════════════════════════════════════════════════
// HTF SECURITY CALLS — must be top level in Pine v6
// ══════════════════════════════════════════════════════════════════════════════

dPH     = request.security(syminfo.tickerid, "D", ta.pivothigh(high, dPiv, dPiv))
dPL     = request.security(syminfo.tickerid, "D", ta.pivotlow(low,   dPiv, dPiv))
wPH     = request.security(syminfo.tickerid, "W", ta.pivothigh(high, wPiv, wPiv))
wPL     = request.security(syminfo.tickerid, "W", ta.pivotlow(low,   wPiv, wPiv))

pdHigh  = request.security(syminfo.tickerid, "D", high[1], lookahead=barmerge.lookahead_on)
pdLow   = request.security(syminfo.tickerid, "D", low[1],  lookahead=barmerge.lookahead_on)
pwHigh  = request.security(syminfo.tickerid, "W", high[1], lookahead=barmerge.lookahead_on)
pwLow   = request.security(syminfo.tickerid, "W", low[1],  lookahead=barmerge.lookahead_on)
ema200d = request.security(syminfo.tickerid, "D", ta.ema(close, 200))

// ══════════════════════════════════════════════════════════════════════════════
// SESSION H/L TRACKING (v2.0.0)
// ══════════════════════════════════════════════════════════════════════════════

inTokyo  = enableSessions and not na(time(timeframe.period, tokyoSess))
inLondon = enableSessions and not na(time(timeframe.period, londonSess))
inNY     = enableSessions and not na(time(timeframe.period, nySess))

var float tokyoH   = na
var float tokyoL   = na
var float tokyoHP  = na
var float tokyoLP  = na
var float londonH  = na
var float londonL  = na
var float londonHP = na
var float londonLP = na
var float nyH      = na
var float nyL      = na
var float nyHP     = na
var float nyLP     = na

// Tokyo tracking — reset on session open, freeze on close
if inTokyo and not inTokyo[1]
    tokyoH := high
    tokyoL := low
else if inTokyo
    tokyoH := math.max(tokyoH, high)
    tokyoL := math.min(tokyoL, low)
if not inTokyo and inTokyo[1]
    tokyoHP := tokyoH
    tokyoLP := tokyoL

// London tracking
if inLondon and not inLondon[1]
    londonH := high
    londonL := low
else if inLondon
    londonH := math.max(londonH, high)
    londonL := math.min(londonL, low)
if not inLondon and inLondon[1]
    londonHP := londonH
    londonLP := londonL

// NY tracking
if inNY and not inNY[1]
    nyH := high
    nyL := low
else if inNY
    nyH := math.max(nyH, high)
    nyL := math.min(nyL, low)
if not inNY and inNY[1]
    nyHP := nyH
    nyLP := nyL

// Active session label
string activeSession = "NONE"
if inTokyo
    activeSession := "TOKYO"
else if inLondon
    activeSession := "LONDON"
else if inNY
    activeSession := "NY"

// Current session H/L for payload (most relevant = active or last closed)
float currentSessH = na
float currentSessL = na
if inTokyo
    currentSessH := tokyoH
    currentSessL := tokyoL
else if inLondon
    currentSessH := londonH
    currentSessL := londonL
else if inNY
    currentSessH := nyH
    currentSessL := nyL
else
    // No active session — use most recent closed session H/L
    currentSessH := not na(nyHP) ? nyHP : not na(londonHP) ? londonHP : tokyoHP
    currentSessL := not na(nyLP) ? nyLP : not na(londonLP) ? londonLP : tokyoLP

// ══════════════════════════════════════════════════════════════════════════════
// ADX DIRECTIONAL BIAS (v2.0.0)
// ══════════════════════════════════════════════════════════════════════════════

[diPlus, diMinus, adxVal] = ta.dmi(adxLen, adxLen)
string adxBias = "NONE"
if enableAdx and adxVal >= adxThresh
    adxBias := diPlus > diMinus ? "LONG" : "SHORT"

// ══════════════════════════════════════════════════════════════════════════════
// USER DEFINED TYPE
// ══════════════════════════════════════════════════════════════════════════════

type Zone
    float  level
    float  top
    float  bot
    string src
    string srcType
    int    touches
    string strength
    bool   confluence
    string conflSrc

// ══════════════════════════════════════════════════════════════════════════════
// HELPER FUNCTIONS
// ══════════════════════════════════════════════════════════════════════════════

countTouches(zTop, zBot) =>
    count = 0
    lastTch = -tchCooldown - 1
    safeLimit = math.min(tchLookback, math.max(0, bar_index - 1))
    if safeLimit > 0
        for i = 0 to safeLimit - 1
            if (i - lastTch) >= tchCooldown
                if low[i] <= zTop and high[i] >= zBot
                    count += 1
                    lastTch := i
    count

toStrength(t) =>
    if t >= exhaustedAt
        "EXHAUSTED"
    else if t >= 3
        "STRONG"
    else if t == 2
        "MODERATE"
    else
        "WEAK"

toLblSize(s) =>
    if s == "tiny"
        size.tiny
    else if s == "normal"
        size.normal
    else if s == "large"
        size.large
    else
        size.small

levelExists(arr, lvl, tol) =>
    found = false
    sz = array.size(arr)
    if sz > 0
        for k = 0 to sz - 1
            if math.abs(array.get(arr, k) - lvl) < tol
                found := true
                break
    found

// ══════════════════════════════════════════════════════════════════════════════
// BREAKOUT DETECTION — runs every bar
// ══════════════════════════════════════════════════════════════════════════════

var float  lastBrokenLvl = na
var int    lastBreakBar  = 0
var string lastBreakDir  = "NONE"
var string lastBreakType = "NONE"

breakState = "NONE"

if useBreakout
    // Break above PDH
    if not na(pdHigh) and close > pdHigh and close[1] <= pdHigh
        lastBrokenLvl := pdHigh
        lastBreakBar  := bar_index
        lastBreakDir  := "ABOVE"
        lastBreakType := "PDH"

    // Break above PWH
    if not na(pwHigh) and close > pwHigh and close[1] <= pwHigh
        lastBrokenLvl := pwHigh
        lastBreakBar  := bar_index
        lastBreakDir  := "ABOVE"
        lastBreakType := "PWH"

    // Break below PDL
    if not na(pdLow) and close < pdLow and close[1] >= pdLow
        lastBrokenLvl := pdLow
        lastBreakBar  := bar_index
        lastBreakDir  := "BELOW"
        lastBreakType := "PDL"

    // Break below PWL
    if not na(pwLow) and close < pwLow and close[1] >= pwLow
        lastBrokenLvl := pwLow
        lastBreakBar  := bar_index
        lastBreakDir  := "BELOW"
        lastBreakType := "PWL"

    // Evaluate active break
    if not na(lastBrokenLvl)
        barsFromBrk = bar_index - lastBreakBar
        proxAbs     = atr14 * retestProxMul
        falseThresh = atr14 * falseBreakMul

        if barsFromBrk > 0 and barsFromBrk <= retestWin
            if lastBreakDir == "ABOVE"
                retesting  = low  <= lastBrokenLvl + proxAbs and close >= lastBrokenLvl - proxAbs
                falseBreak = close < lastBrokenLvl - falseThresh
                if falseBreak
                    breakState    := "FALSE_BREAK"
                    lastBrokenLvl := float(na)
                else if retesting
                    breakState := "BREAKOUT_RETEST"
                else
                    breakState := "BREAKOUT_EXT"

            else if lastBreakDir == "BELOW"
                retesting  = high >= lastBrokenLvl - proxAbs and close <= lastBrokenLvl + proxAbs
                falseBreak = close > lastBrokenLvl + falseThresh
                if falseBreak
                    breakState    := "FALSE_BREAK"
                    lastBrokenLvl := float(na)
                else if retesting
                    breakState := "BREAKOUT_RETEST"
                else
                    breakState := "BREAKOUT_EXT"

        else if barsFromBrk > retestWin
            breakState    := "NONE"
            lastBrokenLvl := float(na)

// ══════════════════════════════════════════════════════════════════════════════
// ZONE COLLECTION + DRAWING — barstate.islast only
// ══════════════════════════════════════════════════════════════════════════════

// These are computed every bar for proximity grading
var float nearSuppLvl  = na
var string nearSuppName = "NONE"
var float nearResLvl   = na
var string nearResName  = "NONE"

// Per-bar level arrays for proximity checking (not just islast)
suppLvls  = array.new_float(0)
suppNames = array.new_string(0)
resLvls   = array.new_float(0)
resNames  = array.new_string(0)

addLevel(lvl, name) =>
    if not na(lvl)
        if lvl >= close
            array.push(resLvls, lvl)
            array.push(resNames, name)
        else
            array.push(suppLvls, lvl)
            array.push(suppNames, name)

if showPDH and not na(pdHigh)
    addLevel(pdHigh, "PDH")
if showPDL and not na(pdLow)
    addLevel(pdLow,  "PDL")
if showPWH and not na(pwHigh)
    addLevel(pwHigh, "PWH")
if showPWL and not na(pwLow)
    addLevel(pwLow,  "PWL")
if showEMA200 and not na(ema200d)
    addLevel(ema200d, "D.200EMA")

// v2.0.0 — Session H/L as magnet-eligible levels
if enableSessions and not na(currentSessH)
    addLevel(currentSessH, "Sess.H")
if enableSessions and not na(currentSessL)
    addLevel(currentSessL, "Sess.L")

if showRound
    effectiveIncr = roundIncr > 0 ? roundIncr : (close > 5000.0 ? 100.0 : close > 500.0 ? 10.0 : close > 50.0 ? 1.0 : close > 5.0 ? 0.5 : close > 1.0 ? 0.01 : 0.001)
    base = math.floor(close / effectiveIncr) * effectiveIncr
    for i = -maxRounds to maxRounds
        lvl = base + i * effectiveIncr
        if math.abs(lvl - close) < atr14 * 15
            addLevel(lvl, "ROUND")

if showDSwings
    for i = 0 to dLookback - 1
        if not na(dPH[i])
            addLevel(dPH[i], "D.SwingH")
        if not na(dPL[i])
            addLevel(dPL[i], "D.SwingL")

if showWSwings
    for i = 0 to wLookback - 1
        if not na(wPH[i])
            addLevel(wPH[i], "W.SwingH")
        if not na(wPL[i])
            addLevel(wPL[i], "W.SwingL")

// Find nearest support and resistance
nearSuppLvl  := float(na)
nearSuppName := "NONE"
nearResLvl   := float(na)
nearResName  := "NONE"

if array.size(suppLvls) > 0
    for k = 0 to array.size(suppLvls) - 1
        lvl = array.get(suppLvls, k)
        if na(nearSuppLvl) or lvl > nearSuppLvl
            nearSuppLvl  := lvl
            nearSuppName := array.get(suppNames, k)

if array.size(resLvls) > 0
    for k = 0 to array.size(resLvls) - 1
        lvl = array.get(resLvls, k)
        if na(nearResLvl) or lvl < nearResLvl
            nearResLvl  := lvl
            nearResName := array.get(resNames, k)

// ══════════════════════════════════════════════════════════════════════════════
// LIQUIDITY MAGNET COUNTING (v2.0.0)
// Counts all levels within magnetThreshAtr of current price.
// Directional count = levels in trade direction (ADX bias preferred, EMA fallback).
// ══════════════════════════════════════════════════════════════════════════════

int magnetsTotal       = 0
int magnetsDirectional = 0
string sweepRisk       = "LOW"
string magnetsJson     = "[]"

// Determine effective trade direction for magnet counting
// ADX bias takes precedence (trend-confirmed); fall back to EMA stack direction
string effDir = direction
if enableAdx and adxBias != "NONE"
    effDir := adxBias

if enableMagnets
    // Build two parallel arrays: all magnets with their sort distance
    magLvls  = array.new_float(0)
    magNames = array.new_string(0)
    magDirs  = array.new_string(0)
    magDists = array.new_float(0)

    // Resistance-side magnets (ahead if direction is LONG)
    if array.size(resLvls) > 0
        for k = 0 to array.size(resLvls) - 1
            lvl  = array.get(resLvls, k)
            dist = (lvl - close) / atr14
            if dist <= magnetThreshAtr
                magnetsTotal := magnetsTotal + 1
                if effDir == "LONG"
                    magnetsDirectional := magnetsDirectional + 1
                array.push(magLvls,  lvl)
                array.push(magNames, array.get(resNames, k))
                array.push(magDirs,  effDir == "LONG" ? "AHEAD" : "BEHIND")
                array.push(magDists, dist)

    // Support-side magnets (ahead if direction is SHORT)
    if array.size(suppLvls) > 0
        for k = 0 to array.size(suppLvls) - 1
            lvl  = array.get(suppLvls, k)
            dist = (close - lvl) / atr14
            if dist <= magnetThreshAtr
                magnetsTotal := magnetsTotal + 1
                if effDir == "SHORT"
                    magnetsDirectional := magnetsDirectional + 1
                array.push(magLvls,  lvl)
                array.push(magNames, array.get(suppNames, k))
                array.push(magDirs,  effDir == "SHORT" ? "AHEAD" : "BEHIND")
                array.push(magDists, dist)

    // Sweep risk tier
    if magnetsDirectional <= sweepLowMax
        sweepRisk := "LOW"
    else if magnetsDirectional <= sweepMedMax
        sweepRisk := "MEDIUM"
    else
        sweepRisk := "HIGH"

    // Build JSON array — cap to magnetMaxShown closest magnets
    // Sort by distance (simple selection — array is small)
    // Guard required: Pine for loops with end < start still iterate once,
    // so we must explicitly check size before sorting.
    if array.size(magLvls) > 1
        n = array.size(magLvls)
        // Simple bubble-sort by distance ascending (n is small, max ~20)
        for i = 0 to n - 2
            for j = 0 to n - i - 2
                if array.get(magDists, j) > array.get(magDists, j + 1)
                    // Swap all four arrays
                    tL  = array.get(magLvls,  j)
                    tN  = array.get(magNames, j)
                    tD  = array.get(magDirs,  j)
                    tDs = array.get(magDists, j)
                    array.set(magLvls,  j, array.get(magLvls,  j + 1))
                    array.set(magNames, j, array.get(magNames, j + 1))
                    array.set(magDirs,  j, array.get(magDirs,  j + 1))
                    array.set(magDists, j, array.get(magDists, j + 1))
                    array.set(magLvls,  j + 1, tL)
                    array.set(magNames, j + 1, tN)
                    array.set(magDirs,  j + 1, tD)
                    array.set(magDists, j + 1, tDs)

    // Build JSON — works for size 0 (empty []), size 1, and size N
    if array.size(magLvls) > 0
        keep = math.min(array.size(magLvls), magnetMaxShown)
        magnetsJson := "["
        for k = 0 to keep - 1
            if k > 0
                magnetsJson := magnetsJson + ","
            mType  = array.get(magNames, k)
            mPrice = str.tostring(array.get(magLvls, k), format.mintick)
            mDist  = str.tostring(math.round(array.get(magDists, k), 2))
            mDir   = array.get(magDirs, k)
            magnetsJson := magnetsJson + '{"type":"' + mType + '","price":"' + mPrice + '","dist_atr":"' + mDist + '","dir":"' + mDir + '"}'
        magnetsJson := magnetsJson + "]"

// Proximity checks
suppDist    = na(nearSuppLvl) ? float(na) : close - nearSuppLvl
resDist     = na(nearResLvl)  ? float(na) : nearResLvl - close
suppDistAtr = na(suppDist)    ? float(na) : math.round(suppDist / atr14, 2)
resDistAtr  = na(resDist)     ? float(na) : math.round(resDist  / atr14, 2)

atSupp = not na(suppDist) and suppDist <= zoneProxAbs
atRes  = not na(resDist)  and resDist  <= zoneProxAbs

// Cloud proximity
inCloud       = close >= cloudLower and close <= cloudUpper
atCloudLower  = (close - cloudLower) >= -(cloudProxAbs * 0.5) and (close - cloudLower) <= cloudProxAbs * 2.0
atCloudUpper  = (cloudUpper - close) >= -(cloudProxAbs * 0.5) and (cloudUpper - close) <= cloudProxAbs * 2.0

cloudPos = "CLEAR"
cloudEdgeAtr = "na"

if direction == "LONG"
    dist = close - cloudLower
    cloudEdgeAtr := str.tostring(math.round(math.abs(dist) / atr14, 2))
    if inCloud
        cloudPos := "INSIDE_CLOUD"
    else if atCloudLower
        cloudPos := "AT_LOWER_EDGE"
    else if dist < 0
        cloudPos := "BELOW_CLOUD"
    else
        cloudPos := "CLEAR"
else if direction == "SHORT"
    dist = cloudUpper - close
    cloudEdgeAtr := str.tostring(math.round(math.abs(dist) / atr14, 2))
    if inCloud
        cloudPos := "INSIDE_CLOUD"
    else if atCloudUpper
        cloudPos := "AT_UPPER_EDGE"
    else if dist < 0
        cloudPos := "ABOVE_CLOUD"
    else
        cloudPos := "CLEAR"

atCloudEdge = false
if direction == "LONG"
    atCloudEdge := atCloudLower or inCloud
else if direction == "SHORT"
    atCloudEdge := atCloudUpper or inCloud

atCorrectZone = false
if direction == "LONG"
    atCorrectZone := atSupp
else if direction == "SHORT"
    atCorrectZone := atRes

atWrongZone = false
if direction == "LONG"
    atWrongZone := atRes
else if direction == "SHORT"
    atWrongZone := atSupp

nearZoneName = "NONE"
if direction == "LONG"
    if atSupp
        nearZoneName := nearSuppName
    else if atRes
        nearZoneName := nearResName
else if direction == "SHORT"
    if atRes
        nearZoneName := nearResName
    else if atSupp
        nearZoneName := nearSuppName

nearZoneDistAtr = "na"
if direction == "LONG" and atSupp
    nearZoneDistAtr := str.tostring(suppDistAtr)
else if direction == "SHORT" and atRes
    nearZoneDistAtr := str.tostring(resDistAtr)
suppDistStr     = na(suppDistAtr) ? "na" : str.tostring(suppDistAtr)
resDistStr      = na(resDistAtr)  ? "na" : str.tostring(resDistAtr)

// ── Grade ─────────────────────────────────────────────────────────────────────
grade = "WAIT"
if direction == "NEUTRAL"
    grade := "NO_DIRECTION"
else if breakState == "BREAKOUT_RETEST"
    grade := "BREAKOUT_RETEST"
else if breakState == "FALSE_BREAK"
    grade := "FALSE_BREAK"
else if breakState == "BREAKOUT_EXT"
    grade := "BREAKOUT_EXT"
else if atWrongZone
    grade := "OPPOSED"
else if atCorrectZone and atCloudEdge
    grade := "PRIME"
else if atCorrectZone
    grade := "AT_ZONE"
else if atCloudEdge and not inCloud
    grade := "AT_CLOUD"
else if inCloud
    grade := "IN_CLOUD"
else
    grade := "WAIT"

// ══════════════════════════════════════════════════════════════════════════════
// ZONE DRAWING — barstate.islast only
// ══════════════════════════════════════════════════════════════════════════════

if barstate.islast
    zones    = array.new<Zone>()
    seenH    = array.new_float(0)
    seenL    = array.new_float(0)

    if showPDH and not na(pdHigh)
        _t1 = pdHigh + hw
        _b1 = pdHigh - hw
        array.push(zones, Zone.new(pdHigh, _t1, _b1, "PDH", "prevday", countTouches(_t1,_b1), toStrength(countTouches(_t1,_b1)), false, ""))
    if showPDL and not na(pdLow)
        _t2 = pdLow + hw
        _b2 = pdLow - hw
        array.push(zones, Zone.new(pdLow, _t2, _b2, "PDL", "prevday", countTouches(_t2,_b2), toStrength(countTouches(_t2,_b2)), false, ""))
    if showPWH and not na(pwHigh)
        _t3 = pwHigh + hw
        _b3 = pwHigh - hw
        array.push(zones, Zone.new(pwHigh, _t3, _b3, "PWH", "prevweek", countTouches(_t3,_b3), toStrength(countTouches(_t3,_b3)), false, ""))
    if showPWL and not na(pwLow)
        _t4 = pwLow + hw
        _b4 = pwLow - hw
        array.push(zones, Zone.new(pwLow, _t4, _b4, "PWL", "prevweek", countTouches(_t4,_b4), toStrength(countTouches(_t4,_b4)), false, ""))

    if showEMA200 and not na(ema200d)
        emaBufAbs = atr14 * emaBufMul
        t  = ema200d + emaBufAbs
        b  = ema200d - emaBufAbs
        tc = countTouches(t, b)
        array.push(zones, Zone.new(ema200d, t, b, "D.200EMA", "ema200", tc, toStrength(tc), false, ""))

    if showRound
        effectiveIncr = roundIncr > 0 ? roundIncr : (close > 5000.0 ? 100.0 : close > 500.0 ? 10.0 : close > 50.0 ? 1.0 : close > 5.0 ? 0.5 : close > 1.0 ? 0.01 : 0.001)
        roundHW = atr14 * 0.35
        base = math.floor(close / effectiveIncr) * effectiveIncr
        for i = -maxRounds to maxRounds
            lvl = base + i * effectiveIncr
            if math.abs(lvl - close) < atr14 * 15
                t  = lvl + roundHW
                b  = lvl - roundHW
                tc = countTouches(t, b)
                if tc >= minRoundTch
                    lbl = "RND " + str.tostring(math.round(lvl / syminfo.mintick) * syminfo.mintick, format.mintick)
                    array.push(zones, Zone.new(lvl, t, b, lbl, "round", tc, toStrength(tc), false, ""))

    if showDSwings
        dHC = 0
        dLC = 0
        for i = 0 to dLookback - 1
            if not na(dPH[i]) and dHC < dMaxZones
                lvl = dPH[i]
                if not levelExists(seenH, lvl, hw)
                    array.push(seenH, lvl)
                    _ts = lvl + hw
                    _bs = lvl - hw
                    array.push(zones, Zone.new(lvl, _ts, _bs, "D.SwingH", "daily", countTouches(_ts,_bs), toStrength(countTouches(_ts,_bs)), false, ""))
                    dHC += 1
            if not na(dPL[i]) and dLC < dMaxZones
                lvl = dPL[i]
                if not levelExists(seenL, lvl, hw)
                    array.push(seenL, lvl)
                    _ts = lvl + hw
                    _bs = lvl - hw
                    array.push(zones, Zone.new(lvl, _ts, _bs, "D.SwingL", "daily", countTouches(_ts,_bs), toStrength(countTouches(_ts,_bs)), false, ""))
                    dLC += 1

    if showWSwings
        wHC = 0
        wLC = 0
        for i = 0 to wLookback - 1
            if not na(wPH[i]) and wHC < wMaxZones
                lvl = wPH[i]
                if not levelExists(seenH, lvl, hw)
                    array.push(seenH, lvl)
                    _ts = lvl + hw
                    _bs = lvl - hw
                    array.push(zones, Zone.new(lvl, _ts, _bs, "W.SwingH", "weekly", countTouches(_ts,_bs), toStrength(countTouches(_ts,_bs)), false, ""))
                    wHC += 1
            if not na(wPL[i]) and wLC < wMaxZones
                lvl = wPL[i]
                if not levelExists(seenL, lvl, hw)
                    array.push(seenL, lvl)
                    _ts = lvl + hw
                    _bs = lvl - hw
                    array.push(zones, Zone.new(lvl, _ts, _bs, "W.SwingL", "weekly", countTouches(_ts,_bs), toStrength(countTouches(_ts,_bs)), false, ""))
                    wLC += 1

    // ── Confluence detection + zone merging ─────────────────────────────────
    // Pass 1: mark all overlapping pairs
    n = array.size(zones)
    if n >= 2
        for i = 0 to n - 2
            zi = array.get(zones, i)
            for j = i + 1 to n - 1
                zj = array.get(zones, j)
                if zi.bot <= zj.top and zi.top >= zj.bot
                    if not zi.confluence
                        zi.confluence := true
                        zi.conflSrc   := zj.src
                    else
                        zi.conflSrc := zi.conflSrc + "+" + zj.src
                    if not zj.confluence
                        zj.confluence := true
                        zj.conflSrc   := zi.src
                    else
                        zj.conflSrc := zj.conflSrc + "+" + zi.src

    // Pass 2: merge overlapping zones using INTERSECTION (not union)
    // The merged box is the overlapping region shared by all zones in the group,
    // capped at 2x zoneHW ATR so it never grows wider than a single zone.
    merged      = array.new<Zone>()
    absorbed    = array.new_bool(0)
    nz          = array.size(zones)
    for k = 0 to nz - 1
        array.push(absorbed, false)

    maxHalfW    = atr14 * zoneHW       // cap: never wider than a single zone
    mergeGapAbs = atr14 * mergeGap     // proximity gap for near-miss merging

    if nz > 0
        for i = 0 to nz - 1
            if not array.get(absorbed, i)
                zi        = array.get(zones, i)
                // Intersection starts as the first zone boundaries
                iTop      = zi.top
                iBot      = zi.bot
                mSrc      = zi.src
                mTouches  = zi.touches
                mConfl    = zi.confluence
                mStrength = zi.strength

                // Absorb overlapping zones, narrowing to intersection
                if i < nz - 1
                    for j = i + 1 to nz - 1
                        if not array.get(absorbed, j)
                            zj = array.get(zones, j)
                            if zj.bot <= iTop + mergeGapAbs and zj.top >= iBot - mergeGapAbs
                                // Intersection: take INNER boundaries (gap zones centre-point merge)
                                if zj.top < iTop
                                    iTop := zj.top
                                if zj.bot > iBot
                                    iBot := zj.bot
                                mSrc := mSrc + "+" + zj.src
                                if zj.touches > mTouches
                                    mTouches := zj.touches
                                mConfl := true
                                if zj.strength == "EXHAUSTED" or mStrength == "EXHAUSTED"
                                    mStrength := "EXHAUSTED"
                                else if zj.strength == "STRONG" or mStrength == "STRONG"
                                    mStrength := "STRONG"
                                else if zj.strength == "MODERATE" or mStrength == "MODERATE"
                                    mStrength := "MODERATE"
                                array.set(absorbed, j, true)

                // Cap height at 2x zoneHW so no merged zone is fatter than a single zone
                mLevel = (iTop + iBot) / 2
                if iTop - iBot > maxHalfW * 2
                    iTop := mLevel + maxHalfW
                    iBot := mLevel - maxHalfW

                array.push(merged, Zone.new(mLevel, iTop, iBot, mSrc, zi.srcType, mTouches, mStrength, mConfl, ""))
                array.set(absorbed, i, true)

    // Draw merged zones
    nm = array.size(merged)
    if nm > 0
        for i = 0 to nm - 1
            z = array.get(merged, i)

            baseCol = switch z.srcType
                "weekly"   => cWeekly
                "daily"    => cDaily
                "prevday"  => cPrevDay
                "prevweek" => cPrevWeek
                "round"    => cRound
                "ema200"   => cEMA
                => color.gray

            drawCol   = z.strength == "EXHAUSTED" ? cExhausted : z.confluence ? cConfluence : baseCol
            bgCol     = color.new(drawCol, 78)
            borderCol = color.new(drawCol, 15)
            borderWid = z.confluence or z.strength == "STRONG" or z.strength == "EXHAUSTED" ? 2 : 1

            box.new(bar_index - tchLookback, z.top, bar_index + extRight, z.bot,
                border_color=borderCol, bgcolor=bgCol, border_width=borderWid)

            if showLbls
                strTag = " [EXH]"
                if z.strength == "STRONG"
                    strTag := " [STR]"
                else if z.strength == "MODERATE"
                    strTag := " [MOD]"
                else if z.strength != "EXHAUSTED"
                    strTag := " [WK]"
                tTxt   = " T:" + str.tostring(z.touches)
                lblTxt = z.src + tTxt + strTag

                label.new(bar_index + extRight + 1, z.level, lblTxt,
                    style=label.style_label_left,
                    color=color.new(drawCol, 55),
                    textcolor=color.white,
                    size=toLblSize(lblSize))

    // Grade label
    if showGradeLbl
        gCol = color.new(#444444, 30)
        if grade == "PRIME" or grade == "BREAKOUT_RETEST"
            gCol := color.new(#FFD700, 10)
        else if grade == "AT_ZONE" or grade == "AT_CLOUD"
            gCol := color.new(#00C853, 20)
        else if grade == "OPPOSED" or grade == "FALSE_BREAK"
            gCol := color.new(#FF1744, 20)
        else if grade == "BREAKOUT_EXT"
            gCol := color.new(#FF8C00, 20)

        clsTag  = showDetected ? " [" + assetClass + "]" : ""
        zoneInf = nearZoneName != "NONE" ? " | " + nearZoneName + " (" + nearZoneDistAtr + " ATR)" : ""
        cldInf  = cloudPos != "CLEAR"    ? " | Cloud: " + cloudPos : ""
        brkInf  = breakState != "NONE"   ? " | BRK: " + breakState : ""
        // v3.1.0 - Profile + effective magnet/sweep params on label for transparency
        profInf = " | mag:" + str.tostring(magnetThreshAtr) + " sw:" + str.tostring(sweepLowMax) + "/" + str.tostring(sweepMedMax)
        lblTxt  = "[FCC-SRL]" + clsTag + " " + direction + " | " + grade + zoneInf + cldInf + brkInf + profInf

        label.new(bar_index, high + atr14 * 0.5, lblTxt,
            style=label.style_label_down,
            color=gCol,
            textcolor=color.white,
            size=size.small)

// ══════════════════════════════════════════════════════════════════════════════
// WEBHOOK — v3.0.0: edge-triggered on grade or sweep tier transition
// (optional heartbeat ping on bar close if `enableHeartbeat` is ON)
// ══════════════════════════════════════════════════════════════════════════════

var string lastGrade     = ""
var string lastSweepRisk = ""
gradeChanged      = grade != lastGrade
sweepChanged      = sweepRisk != lastSweepRisk
lastGrade        := grade
lastSweepRisk    := sweepRisk

// Fire on:
//   1. Real transition (grade or sweep tier changed) — fires immediately, intra-bar
//   2. Heartbeat — only if enabled, on bar close, regardless of change
shouldAlert = (gradeChanged or sweepChanged) or (enableHeartbeat and barstate.isconfirmed)

if shouldAlert
    sessHiStr = na(currentSessH) ? "na" : str.tostring(currentSessH, format.mintick)
    sessLoStr = na(currentSessL) ? "na" : str.tostring(currentSessL, format.mintick)
    adxValStr = str.tostring(math.round(adxVal, 1))

    // Distinguish event type for the receiver
    eventType = (gradeChanged or sweepChanged) ? "TRANSITION" : "HEARTBEAT"

    jsonMsg = '{"pair":"'            + syminfo.ticker    + '"' +
              ',"asset_class":"'     + assetClass         + '"' +
              ',"profile":"'         + profileName        + '"' +
              ',"profile_magnet_atr":' + str.tostring(magnetThreshAtr) +
              ',"profile_sweep_low":'  + str.tostring(sweepLowMax) +
              ',"profile_sweep_med":'  + str.tostring(sweepMedMax) +
              ',"event_type":"'      + eventType          + '"' +
              ',"direction":"'       + direction          + '"' +
              ',"grade":"'           + grade              + '"' +
              ',"zone":"'            + nearZoneName       + '"' +
              ',"zone_dist_atr":"'   + nearZoneDistAtr    + '"' +
              ',"cloud_pos":"'       + cloudPos           + '"' +
              ',"cloud_dist_atr":"'  + cloudEdgeAtr       + '"' +
              ',"breakout":"'        + breakState         + '"' +
              ',"supp_name":"'       + nearSuppName       + '"' +
              ',"supp_dist_atr":"'   + suppDistStr        + '"' +
              ',"res_name":"'        + nearResName        + '"' +
              ',"res_dist_atr":"'    + resDistStr         + '"' +
              ',"active_session":"'  + activeSession      + '"' +
              ',"sess_hi":"'         + sessHiStr          + '"' +
              ',"sess_lo":"'         + sessLoStr          + '"' +
              ',"adx_bias":"'        + adxBias            + '"' +
              ',"adx_value":"'       + adxValStr          + '"' +
              ',"magnets_total":'    + str.tostring(magnetsTotal)       +
              ',"magnets_directional":' + str.tostring(magnetsDirectional) +
              ',"sweep_risk":"'      + sweepRisk          + '"' +
              ',"magnets":'          + magnetsJson        +
              '}'
    alert(jsonMsg, alert.freq_once_per_bar)
