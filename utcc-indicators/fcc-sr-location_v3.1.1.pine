//@version=6
// ══════════════════════════════════════════════════════════════════════════════
// FCC S/R Location Zones — v3.1.1
// Forex Command Centre — S/R visual + location grading + LIQUIDITY MAGNETS
//
// v3.0.0 (MAJOR — breaking change to alert cadence):
//   * Edge-triggered alerts. Webhook now fires the moment grade or sweep risk
//     tier transitions, not on every 4H bar close.
//   * Removed `barstate.isconfirmed` gate. Latency from state change to
//     notification is now seconds, not up to 4 hours.
//   * Removed `alertEveryBar` toggle. It was a leakage point allowing the
//     operator to override system behaviour. Replaced with optional
//     `enableHeartbeat` (default OFF) for liveness-check pings only.
//   * Alert freq changed: `alert.freq_once_per_bar_close` -> `alert.freq_once_per_bar`
//     (allows intra-bar firing, still rate-limited to one fire per bar).
//   * Aligns FCC-SRL with Ultimate UTCC v3.0.0 cadence model. Operator sees
//     the picture change the moment it changes — no more stale grades.
//
// v2.0.2 PATCH:
//   - Fix runtime crash when magnet array has 0 or 1 elements.
//     Pine Script for-loops with end < start still iterate once (e.g.
//     `for i = 0 to -1` runs once with i=0), causing index-out-of-bounds
//     in array.get(arr, j+1) when only 1 magnet exists.
//   - Added explicit size guards: sort requires size > 1, JSON build
//     requires size > 0. magnetsJson stays as "[]" when no magnets found.
//
// v2.0.1 PATCH:
//   - Fix Pine v6 multi-line continuation error inside magnet JSON for-loop
//     Refactored to single-line concatenation with extracted intermediate
//     variables. No functional change.
//
// v2.0.0 CHANGELOG (MAJOR — breaking payload change):
//   + Session H/L tracking (Tokyo/London/NY) as magnet type
//   + ADX directional bias (diPlus/diMinus/ADX) for ahead-of-price logic
//   + Magnet counting: levels within ATR threshold between price and target
//   + Sweep risk tier: LOW / MEDIUM / HIGH (drives FCC tier downgrade)
//   + Extended webhook payload with magnets[] array + sweep_risk fields
// v3.1.0 (2026-05-02):
//   + Per-asset-class magnet/sweep profiles (FX/METALS/ENERGY/INDICES/CRYPTO/BONDS)
//   + magnetThreshAtr / sweepLowMax / sweepMedMax now resolved per asset class
//   + Defaults: FX/Indices/Bonds/Metals = 2.0/2/4 (Metals on test profile),
//     Energy/Crypto = 1.5/2/4 (tighter magnet detection for higher volatility)
//   + 'profile' field added to webhook payload for per-profile analytics
//   + Active profile shown in chart label (institutional transparency)
// v3.1.1 (2026-05-02):
//   * PATCH: Relocate magnet/sweep resolution logic to after per-asset input
//     declarations. v3.1.0 referenced fx_/met_/ene_/idx_/cr_/bnd_ identifiers
//     before they were declared. Pine is single-pass; declarations must precede
//     references. Resolution block now sits immediately after the last
//     per-asset input (bnd_sweepMedMax). Behaviour identical to intended
//     v3.1.0 - this PATCH only resolves the compile error.
//
// Auto-detects asset class: FX | METALS | ENERGY | INDICES | CRYPTO | BONDS
// Applies calibrated profile per class. All values manually overrideable.
//
// What it does:
//   1. Draws S/R zones: Weekly/Daily swings, PDH/PDL, PWH/PWL, session H/L,
//      round numbers, Daily 200 EMA — ATR-scaled boxes, colour-coded
//   2. Touch counting: WEAK / MODERATE / STRONG / EXHAUSTED
//   3. Confluence detection: flags when 2+ sources overlap
//   4. Grades entry location: PRIME / AT_ZONE / AT_CLOUD / IN_CLOUD /
//      WAIT / OPPOSED / BREAKOUT_RETEST / BREAKOUT_EXT / FALSE_BREAK
//   5. Counts LIQUIDITY MAGNETS between current price and target direction
//   6. Classifies SWEEP RISK (LOW/MEDIUM/HIGH) based on directional magnet count
//   7. Fires webhook to FCC alert server on bar close
//
// Webhook payload (JSON) — v2.0.0 extended:
//   {"pair":"EURUSD","asset_class":"FX","direction":"LONG","grade":"PRIME",
//    "zone":"D.SwingL","zone_dist_atr":"0.12","cloud_pos":"AT_LOWER_EDGE",
//    "cloud_dist_atr":"0.08","breakout":"NONE","supp_name":"D.SwingL",
//    "supp_dist_atr":"0.12","res_name":"PDH","res_dist_atr":"1.4",
//    "active_session":"LONDON","sess_hi":"1.0845","sess_lo":"1.0820",
//    "adx_bias":"LONG","adx_value":"24.5",
//    "magnets_total":4,"magnets_directional":2,"sweep_risk":"MEDIUM",
//    "magnets":[{"type":"PDH","price":"1.0870","dist_atr":"0.8","dir":"AHEAD"}, ...]}
//
// Setup:
//   1. Add to each pair on 4H chart (works on 1H and Daily too)
//   2. One TradingView alert per pair — Any Alert() — Webhook:
//      https://api.pineros.club/webhook/location
//   3. Leave alert message blank — indicator sets it dynamically
// ══════════════════════════════════════════════════════════════════════════════

indicator("FCC S/R Location Zones", shorttitle="FCC-SRL", overlay=true,
     max_boxes_count=200, max_labels_count=200, max_lines_count=10)

// Explicitly allocate historical buffer for series used in countTouches()
// Without this Pine may under-allocate and throw buffer limit errors
max_bars_back(high, 500)
max_bars_back(low,  500)

// ══════════════════════════════════════════════════════════════════════════════
// ASSET CLASS DETECTION — mirrors UTCC Universal logic exactly
// Priority: CRYPTO > METALS > ENERGY > BONDS > INDICES > FX
// ══════════════════════════════════════════════════════════════════════════════

_t = str.upper(syminfo.ticker)

bool _isCrypto = syminfo.type == "crypto"
_isCrypto := _isCrypto or str.contains(_t, "BITCOIN") or str.contains(_t, "BTCUSD") or str.contains(_t, "BTC_")
_isCrypto := _isCrypto or str.contains(_t, "ETHEREUM") or str.contains(_t, "ETHUSD") or str.contains(_t, "ETH_")
_isCrypto := _isCrypto or str.contains(_t, "LTCUSD") or str.contains(_t, "XRPUSD") or str.contains(_t, "BCHUSD")
_isCrypto := _isCrypto or str.contains(_t, "SOLUSD") or str.contains(_t, "ADAUSD") or str.contains(_t, "DOTUSD")
_isCrypto := _isCrypto or str.contains(_t, "LINKUSD") or str.contains(_t, "AVAXUSD") or str.contains(_t, "MATICUSD")

bool _isMetals = str.contains(_t, "XAUUSD") or str.contains(_t, "XAGUSD")
_isMetals := _isMetals or str.contains(_t, "XAUEUR") or str.contains(_t, "XAGEUR")
_isMetals := _isMetals or str.contains(_t, "COPPER") or str.contains(_t, "XPTUSD") or str.contains(_t, "XPDUSD")
_isMetals := _isMetals or str.contains(_t, "XAU") or str.contains(_t, "XAG") or str.contains(_t, "XPT") or str.contains(_t, "XPD")
_isMetals := _isMetals or (syminfo.type == "futures" and (str.startswith(_t, "GC") or str.startswith(_t, "SI") or str.startswith(_t, "HG")))

bool _isEnergy = str.contains(_t, "WTICOUSD") or str.contains(_t, "BCOUSD") or str.contains(_t, "NATGASUSD")
_isEnergy := _isEnergy or str.contains(_t, "USOIL") or str.contains(_t, "UKOIL") or str.contains(_t, "NGAS")
_isEnergy := _isEnergy or str.contains(_t, "WTI") or str.contains(_t, "BRENT") or str.contains(_t, "CRUDE")
_isEnergy := _isEnergy or (syminfo.type == "futures" and (str.startswith(_t, "CL") or str.startswith(_t, "LCO")))

bool _isBonds = syminfo.type == "bond"
_isBonds := _isBonds or str.contains(_t, "US02Y") or str.contains(_t, "US10Y") or str.contains(_t, "US30Y")
_isBonds := _isBonds or str.contains(_t, "BUND") or str.contains(_t, "GILT") or str.contains(_t, "JGB")
_isBonds := _isBonds or (syminfo.type == "futures" and (str.startswith(_t, "ZB") or str.startswith(_t, "ZN") or str.startswith(_t, "ZF")))

bool _isIndices = syminfo.type == "index"
_isIndices := _isIndices or str.contains(_t, "SPX") or str.contains(_t, "NAS") or str.contains(_t, "DAX")
_isIndices := _isIndices or str.contains(_t, "FTSE") or str.contains(_t, "NIKKEI") or str.contains(_t, "ASX")
_isIndices := _isIndices or str.contains(_t, "JP225") or str.contains(_t, "AU200") or str.contains(_t, "US500")
_isIndices := _isIndices or str.contains(_t, "WALL") or str.contains(_t, "USTECH") or str.contains(_t, "FT100")
_isIndices := _isIndices or (syminfo.type == "futures" and (str.startswith(_t, "ES") or str.startswith(_t, "NQ") or str.startswith(_t, "YM")))

string detectedClass = "FX"
if _isCrypto and not _isMetals
    detectedClass := "CRYPTO"
else if _isMetals
    detectedClass := "METALS"
else if _isEnergy
    detectedClass := "ENERGY"
else if _isBonds
    detectedClass := "BONDS"
else if _isIndices
    detectedClass := "INDICES"

// ══════════════════════════════════════════════════════════════════════════════
// INPUTS — GENERAL
// ══════════════════════════════════════════════════════════════════════════════

grpGen = "General"
manualClass  = input.string("AUTO", "Asset Class Override", group=grpGen,
                options=["AUTO","FX","METALS","ENERGY","INDICES","CRYPTO","BONDS"],
                tooltip="AUTO = auto-detected. Override if detection is wrong for an unusual instrument.")
showDetected = input.bool(true, "Show Detected Class on Chart", group=grpGen,
                tooltip="Shows [FX], [METALS] etc in the grade label to confirm detection is correct.")
showLbls     = input.bool(true,  "Show Zone Labels",            group=grpGen)
lblSize      = input.string("small", "Label Size",              group=grpGen, options=["tiny","small","normal","large"])
extRight     = input.int(20,  "Extend Boxes Right (bars)",      group=grpGen, minval=0, maxval=200)
showCloud    = input.bool(true, "Show EMA Cloud",               group=grpGen)
enableHeartbeat = input.bool(false, "Enable Bar-Close Heartbeat", group=grpGen,
                tooltip="OFF (default) = webhook fires only on grade or sweep tier transitions. ON = also fires a state ping on every bar close (for liveness checks). Edge-triggered events fire either way.")
showGradeLbl  = input.bool(true, "Show Grade Label on Chart",   group=grpGen)

assetClass = manualClass == "AUTO" ? detectedClass : manualClass

// v3.1.1 - Profile resolution moved to after per-asset input declarations
// (this file is read top-to-bottom by Pine; declarations precede references).
// Search for "PROFILE RESOLUTION (v3.1.1)" below.

// Profile name for label and webhook payload.
// 'FX' covers FX/INDICES/BONDS family at default values; we still record the
// specific assetClass in the webhook so server-side analytics can distinguish.
string profileName = assetClass

// ══════════════════════════════════════════════════════════════════════════════
// INPUTS — ZONE SOURCES
// ══════════════════════════════════════════════════════════════════════════════

grpSrc      = "Zone Sources"
showDSwings = input.bool(true, "Daily Swings",         group=grpSrc)
showWSwings = input.bool(true, "Weekly Swings",        group=grpSrc)
showPDH     = input.bool(true, "Prev Day High (PDH)",  group=grpSrc)
showPDL     = input.bool(true, "Prev Day Low (PDL)",   group=grpSrc)
showPWH     = input.bool(true, "Prev Week High (PWH)", group=grpSrc)
showPWL     = input.bool(true, "Prev Week Low (PWL)",  group=grpSrc)
showRound   = input.bool(true, "Round Numbers",        group=grpSrc)
showEMA200  = input.bool(true, "Daily 200 EMA Zone",   group=grpSrc)
dLookback   = input.int(120, "Daily Search Depth (bars)",  group=grpSrc, minval=50, maxval=1500)
wLookback   = input.int(120, "Weekly Search Depth (bars)", group=grpSrc, minval=50, maxval=1500)
maxRounds   = input.int(1,   "Round Number Levels Above & Below", group=grpSrc, minval=1, maxval=10)
tchLookback = input.int(75,  "Touch Count Lookback (bars)", group=grpSrc, minval=50, maxval=1000)

// ══════════════════════════════════════════════════════════════════════════════
// INPUTS — COLOURS
// ══════════════════════════════════════════════════════════════════════════════

grpC        = "Colours"
cWeekly     = input.color(color.new(#FF3366, 20), "Weekly Swing",            group=grpC)
cDaily      = input.color(color.new(#FF8C00, 25), "Daily Swing",             group=grpC)
cPrevDay    = input.color(color.new(#00BFFF, 25), "Prev Day H/L",            group=grpC)
cPrevWeek   = input.color(color.new(#9370DB, 25), "Prev Week H/L",           group=grpC)
cRound      = input.color(color.new(#20C997, 35), "Round Numbers",           group=grpC)
cEMA        = input.color(color.new(#FFD700, 35), "Daily 200 EMA",           group=grpC)
cConfluence = input.color(color.new(#FF4444, 10), "Confluence (2+ sources)", group=grpC)
cExhausted  = input.color(color.new(#888888, 45), "Exhausted Zone",          group=grpC)
cCloudBull  = input.color(color.new(#00C853, 82), "Cloud Bull",              group=grpC)
cCloudBear  = input.color(color.new(#FF1744, 82), "Cloud Bear",              group=grpC)
cCloudNeut  = input.color(color.new(#888888, 88), "Cloud Neutral",           group=grpC)

// ══════════════════════════════════════════════════════════════════════════════
// INPUTS — DIRECTION EMAs
// ══════════════════════════════════════════════════════════════════════════════

grpDir   = "Direction EMAs"
dirMode  = input.string("AUTO", "Direction Mode", group=grpDir,
            options=["AUTO","LONG","SHORT"],
            tooltip="AUTO uses 9/21/50 EMA stack direction. Override if needed.")
ema9Len  = input.int(9,  "Direction Fast EMA",  group=grpDir, minval=1, maxval=50)
ema21Len = input.int(21, "Direction Mid EMA",   group=grpDir, minval=1, maxval=100)
ema50Len = input.int(50, "Direction Slow EMA",  group=grpDir, minval=1, maxval=200)

// ══════════════════════════════════════════════════════════════════════════════
// INPUTS — BREAKOUT DETECTION
// ══════════════════════════════════════════════════════════════════════════════

grpBrk        = "Breakout Detection"
useBreakout   = input.bool(true,  "Enable Breakout Detection", group=grpBrk)
retestProxMul = input.float(0.3,  "Retest Tolerance ATR x",    group=grpBrk, minval=0.1, maxval=1.0, step=0.1)
falseBreakMul = input.float(0.2,  "False Break Threshold ATR x",group=grpBrk, minval=0.05, maxval=0.5, step=0.05)

// ══════════════════════════════════════════════════════════════════════════════
// INPUTS — LIQUIDITY MAGNETS (v2.0.0)
// ══════════════════════════════════════════════════════════════════════════════

grpMag          = "Liquidity Magnets - Global"
enableMagnets   = input.bool(true,  "Enable Magnet Detection",           group=grpMag,
                    tooltip="Counts S/R levels between current price and trade direction. Drives sweep_risk tier.")
magnetMaxShown  = input.int(6,      "Max Magnets in Payload",            group=grpMag, minval=1, maxval=15,
                    tooltip="Caps magnet array size to limit webhook payload. Closest N are kept.")

// Per-asset profiles for magnetThreshAtr / sweepLowMax / sweepMedMax (v3.1.0)
// Defaults locked in by recalibration analysis 2026-05-02 (TODO P15/P16 diagnosis):
//   FX/Indices/Bonds: 2.0 / 2 / 4 (institutional baseline)
//   Energy/Crypto:    1.5 / 2 / 4 (tighter due to higher volatility regime)
//   Metals:           2.0 / 2 / 4 (TEST profile - same values as FX, separate
//                                  group so post-fix distribution can be observed
//                                  and tuned independently if it diverges)

grpMagFx          = "Liquidity Magnets - FX"
fx_magnetThreshAtr = input.float(2.0, "FX: Magnet Path Threshold (ATR x)", group=grpMagFx, minval=0.5, maxval=5.0, step=0.1)
fx_sweepLowMax     = input.int(2,     "FX: Sweep LOW: directional <= ",    group=grpMagFx, minval=0, maxval=5)
fx_sweepMedMax     = input.int(4,     "FX: Sweep MED: directional <= ",    group=grpMagFx, minval=1, maxval=6)

grpMagMet         = "Liquidity Magnets - Metals (TEST)"
met_magnetThreshAtr = input.float(2.0, "Metals: Magnet Path Threshold (ATR x)", group=grpMagMet, minval=0.5, maxval=5.0, step=0.1,
                        tooltip="TEST profile - starts on FX values. Tune independently if Sweep Risk tab shows Metals diverging from FX.")
met_sweepLowMax     = input.int(2,     "Metals: Sweep LOW: directional <= ",    group=grpMagMet, minval=0, maxval=5)
met_sweepMedMax     = input.int(4,     "Metals: Sweep MED: directional <= ",    group=grpMagMet, minval=1, maxval=6)

grpMagEne         = "Liquidity Magnets - Energy"
ene_magnetThreshAtr = input.float(1.5, "Energy: Magnet Path Threshold (ATR x)", group=grpMagEne, minval=0.5, maxval=5.0, step=0.1,
                        tooltip="Tighter than FX baseline. Energy is volatile and produces wide ATR; tighter threshold prevents false LOW classification.")
ene_sweepLowMax     = input.int(2,     "Energy: Sweep LOW: directional <= ",    group=grpMagEne, minval=0, maxval=5)
ene_sweepMedMax     = input.int(4,     "Energy: Sweep MED: directional <= ",    group=grpMagEne, minval=1, maxval=6)

grpMagIdx         = "Liquidity Magnets - Indices"
idx_magnetThreshAtr = input.float(2.0, "Indices: Magnet Path Threshold (ATR x)", group=grpMagIdx, minval=0.5, maxval=5.0, step=0.1)
idx_sweepLowMax     = input.int(2,     "Indices: Sweep LOW: directional <= ",    group=grpMagIdx, minval=0, maxval=5)
idx_sweepMedMax     = input.int(4,     "Indices: Sweep MED: directional <= ",    group=grpMagIdx, minval=1, maxval=6)

grpMagCr          = "Liquidity Magnets - Crypto"
cr_magnetThreshAtr  = input.float(1.5, "Crypto: Magnet Path Threshold (ATR x)", group=grpMagCr, minval=0.5, maxval=5.0, step=0.1,
                        tooltip="Tighter than FX baseline. Crypto exhibits Energy-like volatility regime.")
cr_sweepLowMax      = input.int(2,     "Crypto: Sweep LOW: directional <= ",    group=grpMagCr, minval=0, maxval=5)
cr_sweepMedMax      = input.int(4,     "Crypto: Sweep MED: directional <= ",    group=grpMagCr, minval=1, maxval=6)

grpMagBnd         = "Liquidity Magnets - Bonds"
bnd_magnetThreshAtr = input.float(2.0, "Bonds: Magnet Path Threshold (ATR x)", group=grpMagBnd, minval=0.5, maxval=5.0, step=0.1)
bnd_sweepLowMax     = input.int(2,     "Bonds: Sweep LOW: directional <= ",    group=grpMagBnd, minval=0, maxval=5)
bnd_sweepMedMax     = input.int(4,     "Bonds: Sweep MED: directional <= ",    group=grpMagBnd, minval=1, maxval=6)
// 3+ = HIGH automatically (per asset class)

// ══════════════════════════════════════════════════════════════════════════════
// PROFILE RESOLUTION (v3.1.1)
// Per-asset profile selects effective magnetThreshAtr / sweepLowMax /
// sweepMedMax. These three vars replace the flat globals everywhere downstream
// of this block. FX is the explicit default fallback.
// ══════════════════════════════════════════════════════════════════════════════

float magnetThreshAtr = fx_magnetThreshAtr
int   sweepLowMax     = fx_sweepLowMax
int   sweepMedMax     = fx_sweepMedMax

if assetClass == "METALS"
    magnetThreshAtr := met_magnetThreshAtr
    sweepLowMax     := met_sweepLowMax
    sweepMedMax     := met_sweepMedMax
else if assetClass == "ENERGY"
    magnetThreshAtr := ene_magnetThreshAtr
    sweepLowMax     := ene_sweepLowMax
    sweepMedMax     := ene_sweepMedMax
else if assetClass == "INDICES"
    magnetThreshAtr := idx_magnetThreshAtr
    sweepLowMax     := idx_sweepLowMax
    sweepMedMax     := idx_sweepMedMax
else if assetClass == "CRYPTO"
    magnetThreshAtr := cr_magnetThreshAtr
    sweepLowMax     := cr_sweepLowMax
    sweepMedMax     := cr_sweepMedMax
else if assetClass == "BONDS"
    magnetThreshAtr := bnd_magnetThreshAtr
    sweepLowMax     := bnd_sweepLowMax
    sweepMedMax     := bnd_sweepMedMax
// FX is the default fallback (already initialised above)


// ══════════════════════════════════════════════════════════════════════════════
// INPUTS — ADX DIRECTIONAL BIAS (v2.0.0)
// ══════════════════════════════════════════════════════════════════════════════

grpAdx          = "ADX Directional Bias"
enableAdx       = input.bool(true,  "Use ADX for directional filter",    group=grpAdx,
                    tooltip="When ADX > threshold, uses diPlus/diMinus to determine trade direction. Falls back to EMA stack if ADX weak.")
adxLen          = input.int(14,     "ADX Length",                         group=grpAdx, minval=5, maxval=50)
adxThresh       = input.float(20.0, "ADX Minimum Threshold",              group=grpAdx, minval=10.0, maxval=40.0, step=1.0,
                    tooltip="ADX below this = no trend confirmation. Institutional default 20.")

// ══════════════════════════════════════════════════════════════════════════════
// INPUTS — SESSION H/L (v2.0.0)
// ══════════════════════════════════════════════════════════════════════════════

grpSess         = "Session High/Low"
enableSessions  = input.bool(true,  "Track Session H/L",                  group=grpSess,
                    tooltip="Tokyo, London, NY session highs and lows. Added as magnet-eligible levels.")
tokyoSess       = input.session("0000-0900",  "Tokyo Session (exchange time)",  group=grpSess,
                    tooltip="Tokyo session in local exchange time. Default 00:00-09:00 JST.")
londonSess      = input.session("0800-1700",  "London Session (exchange time)", group=grpSess,
                    tooltip="London session in local exchange time. Default 08:00-17:00 GMT/BST.")
nySess          = input.session("0930-1700",  "NY Session (exchange time)",     group=grpSess,
                    tooltip="NY session in local exchange time. Default 09:30-17:00 EST/EDT.")
showSessLvls    = input.bool(false, "Draw Session H/L zones on chart",    group=grpSess,
                    tooltip="OFF by default — session lines can clutter chart. Magnet detection works regardless.")

// ══════════════════════════════════════════════════════════════════════════════
// PROFILE — FX
// ══════════════════════════════════════════════════════════════════════════════

grpFX           = "Profile: FX"
fx_zoneHW       = input.float(0.05, "Zone Half-Width ATR x",           group=grpFX, minval=0.01, maxval=2.0, step=0.01)
fx_zoneProx     = input.float(0.2,  "Zone Proximity ATR x",            group=grpFX, minval=0.01, maxval=3.0, step=0.01)
fx_dPivLen      = input.int(10,     "Daily Pivot Strength",             group=grpFX, minval=2, maxval=15)
fx_wPivLen      = input.int(8,      "Weekly Pivot Strength",            group=grpFX, minval=1, maxval=10)
fx_dMaxZones    = input.int(3,      "Max Daily Zones (each direction)", group=grpFX, minval=1, maxval=15)
fx_wMaxZones    = input.int(1,      "Max Weekly Zones (each direction)",group=grpFX, minval=1, maxval=10)
fx_cloudFast    = input.int(9,      "Cloud Fast EMA",                   group=grpFX, minval=1, maxval=50)
fx_cloudSlow    = input.int(21,     "Cloud Slow EMA",                   group=grpFX, minval=1, maxval=200)
fx_cloudProx    = input.float(0.5,  "Cloud Proximity ATR x",            group=grpFX, minval=0.01, maxval=3.0, step=0.01)
fx_emaBuf       = input.float(0.3,  "200 EMA Zone Width ATR x",         group=grpFX, minval=0.01, maxval=3.0, step=0.01)
fx_tchCooldown  = input.int(10,     "Touch Cooldown (bars)",             group=grpFX, minval=1, maxval=30)
fx_exhausted    = input.int(6,      "Exhausted At (touches)",            group=grpFX, minval=2, maxval=10)
